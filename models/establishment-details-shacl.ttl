#
# Covers: Further education, Sixth form centre
#################################################################

epr:CollegeGroupShape
    a sh:NodeShape ;
    rdfs:label "College group shape"@en ;
    rdfs:comment "Rules for FE colleges and sixth form centres. No accountability relationships, no provision classifications and no faith context apply. Education phase and gender of entry are present in the GIAS record and are retained."@en ;
    sh:targetClass epr:College ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToLocalAuthority ) ;
        sh:maxCount 0 ;
        sh:name "Local authority - accountability relationship (not applicable)"@en ;
        sh:message "Colleges do not have LA accountability relationships."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToAcademyTrust ) ;
        sh:maxCount 0 ;
        sh:name "Academy trust (not applicable)"@en ;
        sh:message "Colleges do not have academy trust accountability relationships."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToProprietor ) ;
        sh:maxCount 0 ;
        sh:name "Proprietor (not applicable)"@en ;
        sh:message "Colleges do not have proprietor accountability relationships."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByAdmissionsPolicy ) ;
        sh:maxCount 0 ;
        sh:name "Admissions policy (not applicable)"@en ;
        sh:message "Admissions policy is not applicable for colleges."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByNurseryProvision ) ;
        sh:maxCount 0 ;
        sh:name "Nursery provision (not applicable)"@en ;
        sh:message "Nursery provision is not applicable for colleges."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySixthFormProvision ) ;
        sh:maxCount 0 ;
        sh:name "Sixth-form provision (not applicable)"@en ;
        sh:message "Sixth-form provision classification is not applicable for colleges - these establishments are sixth form or further education."@en ;
    ] ;

    sh:property [
        sh:path epro:hasFaithContext ;
        sh:maxCount 0 ;
        sh:name "Faith context (not applicable)"@en ;
        sh:message "Faith context is not applicable for colleges."@en ;
    ] ;

    sh:property [
        sh:path epro:hasSenAndResourcedProvision ;
        sh:maxCount 0 ;
        sh:name "SEN and resourced provision (not applicable)"@en ;
        sh:message "SEN and resourced provision is not applicable for colleges."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:hasStatutoryAgeRange ) ;
        sh:minCount 1 ;
        sh:name "Age range"@en ;
        sh:message "Colleges must have a statutory age range."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasCapacityAndPupilMeasures epro:hasSchoolCapacity ) ;
        sh:maxCount 0 ;
        sh:name "School capacity (not applicable)"@en ;
        sh:message "School capacity is not applicable for colleges."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasCapacityAndPupilMeasures epro:hasPupilCount ) ;
        sh:minCount 1 ;
        sh:name "Number of pupils"@en ;
        sh:message "Colleges must have a pupil count."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasCapacityAndPupilMeasures epro:hasFreeSchoolMealMeasure ) ;
        sh:minCount 1 ;
        sh:name "Number of pupils eligible for free school meals"@en ;
        sh:message "Colleges must have a free school meal measure."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentClassification epro:classifiedBySection41ApprovalStatus ) ;
        sh:maxCount 0 ;
        sh:name "Section 41 approved (not applicable)"@en ;
        sh:message "Section 41 approval is not applicable for colleges."@en ;
    ] .

    # Note: Further education type (classifiedByFurtherEducationType) applies to type 18
    # (FurtherEducation) but not type 31 (SixthFormCentre). Ofsted inspection applies to
    # type 18 but not type 31. These field differences cannot be expressed at group level
    # without splitting the shape. A shape split for FE colleges vs sixth form centres
    # should be considered in a future version.


