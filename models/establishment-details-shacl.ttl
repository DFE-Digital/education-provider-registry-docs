@prefix epr:     <https://dfe-digital.github.io/education-provider-registry-docs/vocabulary/> .
@prefix epro:    <https://dfe-digital.github.io/education-provider-registry-docs/ontology/> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# GIAS 2.0 Establishment Details - SHACL Shapes
#
# Scope: field-applicability constraints for the ~39 GIAS establishment types.
# Shapes are organised by type group. Rules within a group apply to every type
# in that group unless a more specific shape overrides them.
#
# Sits alongside:
#   establishment-details-conceptual-model.ttl  (OWL ontology)
#   establishment-details-taxonomy-skos.ttl     (SKOS taxonomy)
#   establishment-details-vocabulary-skos.ttl   (SKOS vocabulary)
#
# All shapes are provisional. Rules for "Other types" (secure units, offshore
# schools, service children's education, miscellaneous, British schools overseas,
# institution funded by other government department) require further data analysis
# before strong constraints can be added.


#################################################################
# Shapes graph declaration
#################################################################

<https://dfe-digital.github.io/education-provider-registry-docs/shapes/>
    a owl:Ontology ;
    dcterms:title "GIAS 2.0 Establishment Details SHACL Shapes"@en ;
    dcterms:description "SHACL node shapes expressing per-type and per-group field-applicability rules for GIAS establishment records."@en ;
    dcterms:created "2026-06-19"^^xsd:date ;
    dcterms:modified "2026-06-19"^^xsd:date ;
    dcterms:publisher "Department for Education"@en ;
    dcterms:license <https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
    owl:versionInfo "0.5" ;
    rdfs:seeAlso <https://dfe-digital.github.io/education-provider-registry-docs/ontology/> ;
    rdfs:seeAlso <https://dfe-digital.github.io/education-provider-registry-docs/taxonomy/> ;
    epr:status "Provisional"@en .


#################################################################
# Universal shape - applies to every establishment
#################################################################

epr:EstablishmentUniversalShape
    a sh:NodeShape ;
    rdfs:label "Universal establishment shape"@en ;
    rdfs:comment "Constraints that apply to every establishment regardless of type."@en ;
    sh:targetClass epr:Establishment ;

    sh:property [
        sh:path epro:hasEstablishmentIdentity ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Establishment identity"@en ;
        sh:message "Every establishment must have exactly one identity record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentIdentity epro:identifiedByUrn ) ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "URN"@en ;
        sh:message "Every establishment identity must include exactly one URN."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentIdentity epro:hasUkprn ) ;
        sh:maxCount 1 ;
        sh:name "UKPRN"@en ;
        sh:message "An establishment identity may have at most one UKPRN."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentIdentity epro:hasLocalAuthorityScopedEstablishmentNumber ) ;
        sh:maxCount 2 ;
        sh:name "Local-authority-scoped establishment number"@en ;
        sh:message "An establishment identity may have at most one current and one previous scoped establishment number."@en ;
    ] ;

    sh:property [
        sh:path epro:hasEstablishmentLifecycle ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Establishment lifecycle"@en ;
        sh:message "Every establishment must have exactly one lifecycle record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentLifecycle epro:classifiedByEstablishmentStatus ) ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Establishment status"@en ;
        sh:message "Every establishment lifecycle must carry exactly one status."@en ;
    ] ;

    sh:property [
        sh:path epro:hasEstablishmentClassification ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Establishment classification"@en ;
        sh:message "Every establishment must have exactly one classification record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentClassification epro:hasEstablishmentType ) ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Establishment type"@en ;
        sh:message "Every establishment classification must carry exactly one establishment type."@en ;
    ] ;

    sh:property [
        sh:path epro:hasContactAndLocation ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Contact and location"@en ;
        sh:message "Every establishment must have exactly one contact and location record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasContactAndLocation epro:hasPostalAddress ) ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Postal address"@en ;
        sh:message "Every establishment must have a postal address."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasContactAndLocation epro:hasHeadteacherOrPrincipal ) ;
        sh:maxCount 1 ;
        sh:name "Headteacher or principal"@en ;
        sh:message "An establishment may have at most one headteacher or principal record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasContactAndLocation epro:hasWebsiteUrl ) ;
        sh:maxCount 1 ;
        sh:name "Website"@en ;
        sh:message "An establishment may have at most one website URL."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasContactAndLocation epro:hasTelephoneNumber ) ;
        sh:maxCount 1 ;
        sh:name "Telephone number"@en ;
        sh:message "An establishment may have at most one telephone number."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentLifecycle epro:hasOpenDate ) ;
        sh:maxCount 1 ;
        sh:name "Open date"@en ;
        sh:message "An establishment may have at most one open date."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentLifecycle epro:hasReasonEstablishmentOpened ) ;
        sh:maxCount 1 ;
        sh:name "Reason establishment opened"@en ;
        sh:message "An establishment may have at most one reason for opening."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentLifecycle epro:hasClosedDate ) ;
        sh:maxCount 1 ;
        sh:name "Closed date"@en ;
        sh:message "An establishment may have at most one closed date."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentLifecycle epro:hasReasonEstablishmentClosed ) ;
        sh:maxCount 1 ;
        sh:name "Reason establishment closed"@en ;
        sh:message "An establishment may have at most one reason for closing."@en ;
    ] ;

    sh:property [
        sh:path epro:hasCapacityAndPupilMeasures ;
        sh:maxCount 1 ;
        sh:name "Capacity and pupil measures"@en ;
        sh:message "An establishment may have at most one capacity and pupil measures record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasCapacityAndPupilMeasures epro:hasPupilCount ) ;
        sh:maxCount 1 ;
        sh:name "Number of pupils"@en ;
        sh:message "An establishment may have at most one pupil count."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasCapacityAndPupilMeasures epro:hasFreeSchoolMealMeasure ) ;
        sh:maxCount 1 ;
        sh:name "Free school meal measure"@en ;
        sh:message "An establishment may have at most one free school meal measure record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasRecordCurrency epro:recordsDateLastChanged ) ;
        sh:minCount 1 ;
        sh:name "Date last changed / confirmed"@en ;
        sh:message "Every establishment must have a date last changed or confirmed record."@en ;
    ] .


#################################################################
# Group shape - LA maintained schools
#
# Covers: Community school, Voluntary aided school,
#         Voluntary controlled school, Foundation school,
#         Community special school, Foundation special school,
#         Pupil referral unit, Local authority nursery school
#################################################################

epr:LaMaintainedSchoolGroupShape
    a sh:NodeShape ;
    rdfs:label "LA maintained school group shape"@en ;
    rdfs:comment "Rules shared by all LA maintained school types. More specific shapes override individual fields for special schools, PRUs and nursery schools."@en ;
    sh:targetClass epr:LaMaintainedSchool ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToLocalAuthority ) ;
        sh:minCount 1 ;
        sh:name "Local authority"@en ;
        sh:message "LA maintained schools must have at least one local authority accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToAcademyTrust ) ;
        sh:maxCount 0 ;
        sh:name "Academy trust (forbidden)"@en ;
        sh:message "LA maintained schools must not have an academy trust accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasAccountabilityRelationship epro:accountableToProprietor ) ;
        sh:maxCount 0 ;
        sh:name "Proprietor (forbidden)"@en ;
        sh:message "LA maintained schools must not have a proprietor accountability relationship."@en ;
    ] ;

    sh:property [
        sh:path epro:hasEducationAdmissionsAndProvision ;
        sh:minCount 1 ; sh:maxCount 1 ;
        sh:name "Education, admissions and provision"@en ;
        sh:message "LA maintained schools must have an education, admissions and provision record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByGenderOfEntry ) ;
        sh:minCount 1 ;
        sh:name "Gender of entry"@en ;
        sh:message "LA maintained schools must have a gender-of-entry classification."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByBoardingProvision ) ;
        sh:minCount 1 ;
        sh:name "Boarding provision"@en ;
        sh:message "LA maintained schools must have a boarding-provision classification."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:hasStatutoryAgeRange ) ;
        sh:minCount 1 ;
        sh:name "Age range"@en ;
        sh:message "LA maintained schools must have a statutory age range."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasCapacityAndPupilMeasures epro:hasSchoolCapacity ) ;
        sh:maxCount 1 ;
        sh:name "School capacity"@en ;
        sh:message "An LA maintained school may have at most one school capacity."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasCapacityAndPupilMeasures epro:hasPupilCount ) ;
        sh:minCount 1 ;
        sh:name "Number of pupils"@en ;
        sh:message "LA maintained schools must have a pupil count."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasCapacityAndPupilMeasures epro:hasFreeSchoolMealMeasure ) ;
        sh:minCount 1 ;
        sh:name "Number of pupils eligible for free school meals"@en ;
        sh:message "LA maintained schools must have a free school meal measure."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentClassification epro:classifiedBySection41ApprovalStatus ) ;
        sh:maxCount 0 ;
        sh:name "Section 41 approved (not applicable)"@en ;
        sh:message "Section 41 approval is not applicable for LA maintained schools."@en ;
    ] ;

    sh:property [
        sh:path epro:hasOfstedInspectionRecord ;
        sh:minCount 1 ;
        sh:name "Ofsted rating and reports"@en ;
        sh:message "LA maintained schools must have an Ofsted inspection record."@en ;
    ] .


#################################################################
# Specific shape - LA mainstream schools
#
# Covers: Community school, Voluntary aided school,
#         Voluntary controlled school, Foundation school
#################################################################

epr:LaMainstreamSchoolShape
    a sh:NodeShape ;
    rdfs:label "LA mainstream school shape"@en ;
    rdfs:comment "Rules for mainstream LA maintained school types. Admissions policy, nursery, sixth form and education phase are all required."@en ;
    sh:targetClass epr:LaMainstreamSchool ;

    sh:property [
        sh:path ( epro:hasEstablishmentClassification epro:hasEducationPhase ) ;
        sh:minCount 1 ;
        sh:name "Education phase"@en ;
        sh:message "LA mainstream schools must have an education phase."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByAdmissionsPolicy ) ;
        sh:minCount 1 ;
        sh:name "Admissions policy"@en ;
        sh:message "LA mainstream schools must have an admissions policy."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByNurseryProvision ) ;
        sh:minCount 1 ;
        sh:name "Nursery provision"@en ;
        sh:message "LA mainstream schools must have a nursery-provision classification."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySixthFormProvision ) ;
        sh:minCount 1 ;
        sh:name "Sixth-form provision"@en ;
        sh:message "LA mainstream schools must have a sixth-form-provision classification."@en ;
    ] ;

    sh:property [
        sh:path epro:hasFaithContext ;
        sh:minCount 1 ;
        sh:name "Faith context"@en ;
        sh:message "LA mainstream schools must have a faith context record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasFaithContext epro:classifiedByReligiousCharacter ) ;
        sh:minCount 1 ;
        sh:name "Religious character"@en ;
        sh:message "LA mainstream schools must have a religious character classification."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasFaithContext epro:associatedWithDiocese ) ;
        sh:minCount 1 ;
        sh:name "Diocese"@en ;
        sh:message "LA mainstream schools must have a diocese association."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasFaithContext epro:classifiedByReligiousEthos ) ;
        sh:maxCount 0 ;
        sh:name "Religious ethos (not applicable)"@en ;
        sh:message "Religious ethos is not applicable for LA mainstream schools (types 01, 02, 03, 05)."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySpecialClassProvision ) ;
        sh:minCount 1 ;
        sh:name "Special classes"@en ;
        sh:message "LA mainstream schools must have a special-class provision classification."@en ;
    ] ;

    sh:property [
        sh:path epro:hasSenAndResourcedProvision ;
        sh:minCount 1 ;
        sh:name "SEN and resourced provision"@en ;
        sh:message "LA mainstream schools must have a SEN and resourced provision record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasSenAndResourcedProvision epro:classifiedByTypeOfResourcedProvision ) ;
        sh:minCount 1 ;
        sh:name "Type of resourced provision"@en ;
        sh:message "LA mainstream schools must have a type of resourced provision classification."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasSenAndResourcedProvision epro:hasResourcedProvisionMeasure ) ;
        sh:minCount 1 ;
        sh:name "Resourced provision number on roll and capacity"@en ;
        sh:message "LA mainstream schools must have resourced provision measures."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasSenAndResourcedProvision epro:hasSenUnitMeasure ) ;
        sh:minCount 1 ;
        sh:name "SEN unit number on roll and capacity"@en ;
        sh:message "LA mainstream schools must have SEN unit measures."@en ;
    ] .


#################################################################
# Specific shape - LA special schools
#
# Covers: Community special school, Foundation special school
#################################################################

epr:LaSpecialSchoolShape
    a sh:NodeShape ;
    rdfs:label "LA special school shape"@en ;
    rdfs:comment "Rules for LA maintained special schools. SEN provision is required. Sixth-form provision is not applicable."@en ;
    sh:targetClass epr:LaMaintainedSpecialSchool ;

    sh:property [
        sh:path epro:hasSenAndResourcedProvision ;
        sh:minCount 1 ;
        sh:name "SEN and resourced provision"@en ;
        sh:message "LA special schools must have a SEN and resourced provision record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySixthFormProvision ) ;
        sh:maxCount 0 ;
        sh:name "Sixth-form provision (not applicable)"@en ;
        sh:message "Sixth-form provision is not applicable for LA special schools."@en ;
    ] ;

    sh:property [
        sh:path epro:hasFaithContext ;
        sh:minCount 1 ;
        sh:name "Faith context"@en ;
        sh:message "LA special schools must have a faith context record."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasFaithContext epro:classifiedByReligiousCharacter ) ;
        sh:minCount 1 ;
        sh:name "Religious character"@en ;
        sh:message "LA special schools must have a religious character classification."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasFaithContext epro:associatedWithDiocese ) ;
        sh:minCount 1 ;
        sh:name "Diocese"@en ;
        sh:message "LA special schools must have a diocese association."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasFaithContext epro:classifiedByReligiousEthos ) ;
        sh:maxCount 0 ;
        sh:name "Religious ethos (not applicable)"@en ;
        sh:message "Religious ethos is not applicable for LA special schools."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySpecialClassProvision ) ;
        sh:minCount 1 ;
        sh:name "Special classes"@en ;
        sh:message "LA special schools must have a special-class provision classification."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasSenAndResourcedProvision epro:classifiedByTypeOfResourcedProvision ) ;
        sh:minCount 1 ;
        sh:name "Type of resourced provision"@en ;
        sh:message "LA special schools must have a type of resourced provision classification."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasSenAndResourcedProvision epro:hasResourcedProvisionMeasure ) ;
        sh:minCount 1 ;
        sh:name "Resourced provision number on roll and capacity"@en ;
        sh:message "LA special schools must have resourced provision measures."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasSenAndResourcedProvision epro:hasSenUnitMeasure ) ;
        sh:minCount 1 ;
        sh:name "SEN unit number on roll and capacity"@en ;
        sh:message "LA special schools must have SEN unit measures."@en ;
    ] .


#################################################################
# Specific shape - Pupil referral unit
#################################################################

epr:PupilReferralUnitShape
    a sh:NodeShape ;
    rdfs:label "Pupil referral unit shape"@en ;
    rdfs:comment "Rules for PRUs. Nursery provision, sixth-form provision and boarding provision are not applicable."@en ;
    sh:targetClass epr:PupilReferralUnit ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByNurseryProvision ) ;
        sh:maxCount 0 ;
        sh:name "Nursery provision (not applicable)"@en ;
        sh:message "Nursery provision is not applicable for pupil referral units."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedBySixthFormProvision ) ;
        sh:maxCount 0 ;
        sh:name "Sixth-form provision (not applicable)"@en ;
        sh:message "Sixth-form provision is not applicable for pupil referral units."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEducationAdmissionsAndProvision epro:classifiedByBoardingProvision ) ;
        sh:maxCount 0 ;
        sh:name "Boarding provision (not applicable)"@en ;
        sh:message "Boarding provision is not applicable for pupil referral units."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasCapacityAndPupilMeasures epro:hasSchoolCapacity ) ;
        sh:maxCount 0 ;
        sh:name "School capacity (not applicable)"@en ;
        sh:message "School capacity is not applicable for pupil referral units."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasCapacityAndPupilMeasures epro:hasPupilCount ) ;
        sh:minCount 1 ;
        sh:name "Number of pupils"@en ;
        sh:message "Pupil referral units must have a pupil count."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasCapacityAndPupilMeasures epro:hasFreeSchoolMealMeasure ) ;
        sh:minCount 1 ;
        sh:name "Number of pupils eligible for free school meals"@en ;
        sh:message "Pupil referral units must have a free school meal measure."@en ;
    ] ;

    sh:property [
        sh:path ( epro:hasEstablishmentClassification epro:classifiedByFurtherEducationType ) ;
        sh:minCount 1 ;
        sh:name "Further education type"@en ;
        sh:message "Pupil referral units must have a further education type classification."@en ;
    ] ;

    sh:property [
        sh:path epro:hasOfstedInspectionRecord ;
        sh:minCount 1 ;
        sh:name "Ofsted rating and reports"@en ;
        sh:message "Pupil referral units must have an Ofsted inspection record."@en ;
    ] ;

    sh:property [
        sh:path epro:hasSenAndResourcedProvision ;
        sh:maxCount 0 ;
        sh:name "SEN and resourced provision (not applicable)"@en ;
        sh:message "SEN and resourced provision fields are not shown for pupil referral units."@en ;
    ] ;

    sh:property [
        sh:path epro:hasFaithContext ;
        sh:maxCount 0 ;
        sh:name "Faith context (not applicable)"@en ;
        sh:message "Faith context is not applicable for pupil referral units."@en ;
    ] ;

    sh:property [
        sh:path epro:hasPupilReferralUnitOperationalRecord ;
        sh:minCount 1 ;
        sh:name "PRU operational fields"@en ;
        sh:message "Pupil referral units must have a PRU operational record."@en ;
    ] .


#################################################################
# Specific shape - Local authority nursery school
#################################################################

epr:LocalAuthorityNurserySchoolShape
    a sh:NodeShape ;
    rdfs:label "Local authority nursery school shape"@en ;
