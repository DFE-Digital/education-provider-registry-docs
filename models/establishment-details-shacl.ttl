    sh:property [
        sh:path ( epro:hasSenAndResourcedProvision epro:hasSpecialPupilMeasure ) ;
        sh:minCount 1 ;
        sh:name "Special pupil SEN measures"@en ;
        sh:message "Online providers must have special pupil SEN measures."@en ;
    ] ;

    sh:property [
        sh:path epro:hasAccreditationRecord ;
        sh:minCount 1 ;
        sh:name "Accreditation record"@en ;
        sh:message "Online providers must have an accreditation record."@en ;
    ] .


#################################################################
# Specific shape - Welsh establishment
#################################################################

epr:WelshEstablishmentShape
    a sh:NodeShape ;
    rdfs:label "Welsh establishment shape"@en ;
    rdfs:comment "Rules for Welsh establishments. LA accountability and education phase are required. Gender of entry, admissions policy and boarding provision are not present in the GIAS record for Welsh establishments and are not modelled as required here."@en ;
    sh:targetClass epr:WelshEstablishment ;

