@prefix epr:     <https://dfe-digital.github.io/education-provider-registry-docs/vocabulary/> .
@prefix epro:    <https://dfe-digital.github.io/education-provider-registry-docs/ontology/> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .

# GIAS 2.0 Establishment Details - Data Quality SHACL Shapes
#
# Scope: value-level constraints on EPR establishment fields.
# This file constrains datatypes, ranges and cardinality for properties
# already defined in establishment-details-conceptual-model.ttl.
#
# It is separate from establishment-details-shacl.ttl, which constrains
# structural shape (which fields are required, optional or not applicable
# per establishment type). Both files can be validated together or
# independently.
#
# Convention: scalar values are attached to class instances via rdf:value.
# For example, a UniqueReferenceNumber instance carries its integer value
# as rdf:value. Compound measures (e.g. FSM count + percentage) use
# named vocabulary properties - see deferred items at the end of this file.
#
# Sits alongside:
#   establishment-details-conceptual-model.ttl  (OWL ontology - v0.3)
#   establishment-details-shacl.ttl             (structural SHACL - v0.2)
#   establishment-details-taxonomy-skos.ttl     (SKOS taxonomy)
#   establishment-details-vocabulary-skos.ttl   (SKOS vocabulary)


#################################################################
# Shapes graph declaration
#################################################################

<https://dfe-digital.github.io/education-provider-registry-docs/shapes/data-quality/>
    a owl:Ontology ;
    dcterms:title "GIAS 2.0 Establishment Details Data Quality SHACL Shapes"@en ;
    dcterms:description "Value-level SHACL constraints for EPR establishment records: datatypes, numeric ranges and cardinality rules for identity, lifecycle and measure fields."@en ;
    dcterms:created "2026-06-19"^^xsd:date ;
    dcterms:modified "2026-06-19"^^xsd:date ;
    dcterms:publisher "Department for Education"@en ;
    dcterms:license <https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
    owl:versionInfo "0.1" ;
    rdfs:seeAlso <https://dfe-digital.github.io/education-provider-registry-docs/ontology/> ;
    rdfs:seeAlso <https://dfe-digital.github.io/education-provider-registry-docs/shapes/> ;
    epr:status "Provisional"@en .


#################################################################
# Identity - URN
#################################################################

epr:UrnValueShape
    a sh:NodeShape ;
    sh:targetClass epr:UniqueReferenceNumber ;
    rdfs:label "URN value shape"@en ;
    rdfs:comment "A URN must carry exactly one value, which must be a positive integer in the 6-digit GIAS range."@en ;

    sh:property [
        sh:path rdf:value ;
        sh:datatype xsd:positiveInteger ;
        sh:minInclusive 100000 ;
        sh:maxInclusive 999999 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "URN value"@en ;
        sh:message "URN must be a 6-digit positive integer between 100000 and 999999."@en ;
    ] .


#################################################################
# Identity - UKPRN
#################################################################

epr:UkprnValueShape
    a sh:NodeShape ;
    sh:targetClass epr:UkProviderReferenceNumber ;
    rdfs:label "UKPRN value shape"@en ;
    rdfs:comment "A UKPRN must carry exactly one value, which must be an 8-digit positive integer."@en ;

    sh:property [
        sh:path rdf:value ;
        sh:datatype xsd:positiveInteger ;
        sh:minInclusive 10000000 ;
        sh:maxInclusive 99999999 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "UKPRN value"@en ;
        sh:message "UKPRN must be an 8-digit positive integer between 10000000 and 99999999."@en ;
    ] .


#################################################################
# Identity - establishment number
#################################################################

epr:EstablishmentNumberValueShape
    a sh:NodeShape ;
    sh:targetClass epr:EstablishmentNumber ;
    rdfs:label "Establishment number value shape"@en ;
    rdfs:comment "An establishment number must carry exactly one value, a positive integer between 1 and 9999. The four-digit zero-padded display form belongs to DfE number / LAESTAB rendering, not the stored value."@en ;

    sh:property [
        sh:path rdf:value ;
        sh:datatype xsd:positiveInteger ;
        sh:minInclusive 1 ;
        sh:maxInclusive 9999 ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Establishment number value"@en ;
        sh:message "Establishment number must be a positive integer between 1 and 9999."@en ;
    ] .


#################################################################
# Lifecycle - dates
#################################################################

epr:OpenDateValueShape
    a sh:NodeShape ;
    sh:targetClass epr:OpenDate ;
    rdfs:label "Open date value shape"@en ;

    sh:property [
        sh:path rdf:value ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Open date value"@en ;
        sh:message "Open date must be an xsd:date value."@en ;
    ] .

epr:ClosedDateValueShape
    a sh:NodeShape ;
    sh:targetClass epr:ClosedDate ;
    rdfs:label "Closed date value shape"@en ;

    sh:property [
        sh:path rdf:value ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Closed date value"@en ;
        sh:message "Closed date must be an xsd:date value."@en ;
    ] .

epr:DateLastChangedValueShape
    a sh:NodeShape ;
    sh:targetClass epr:DateLastChangedOrConfirmed ;
    rdfs:label "Date last changed value shape"@en ;

    sh:property [
        sh:path rdf:value ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Date last changed value"@en ;
        sh:message "Date last changed or confirmed must be an xsd:date value."@en ;
    ] .


#################################################################
# Lifecycle - inspection dates (BSO and independent schools)
#################################################################

epr:DateOfLastInspectionVisitValueShape
    a sh:NodeShape ;
    sh:targetClass epr:DateOfLastInspectionVisit ;
    rdfs:label "Date of last inspection visit value shape"@en ;

    sh:property [
        sh:path rdf:value ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Date of last inspection visit value"@en ;
        sh:message "Date of last inspection visit must be an xsd:date value."@en ;
    ] .

epr:DateOfNextInspectionVisitValueShape
    a sh:NodeShape ;
    sh:targetClass epr:DateOfNextInspectionVisit ;
    rdfs:label "Date of next inspection visit value shape"@en ;

    sh:property [
        sh:path rdf:value ;
        sh:datatype xsd:date ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Date of next inspection visit value"@en ;
        sh:message "Date of next inspection visit must be an xsd:date value."@en ;
    ] .


#################################################################
# Capacity and pupil measures
#################################################################

epr:SchoolCapacityValueShape
    a sh:NodeShape ;
    sh:targetClass epr:SchoolCapacity ;
    rdfs:label "School capacity value shape"@en ;

    sh:property [
        sh:path rdf:value ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "School capacity value"@en ;
        sh:message "School capacity must be a non-negative integer."@en ;
    ] .

epr:PupilCountValueShape
    a sh:NodeShape ;
    sh:targetClass epr:PupilCount ;
    rdfs:label "Pupil count value shape"@en ;

    sh:property [
        sh:path rdf:value ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:name "Pupil count value"@en ;
        sh:message "Pupil count must be a non-negative integer."@en ;
    ] .


#################################################################
# SEN and resourced provision measures
#################################################################

epr:ResourcedProvisionMeasureShape
    a sh:NodeShape ;
    sh:targetClass epr:ResourcedProvisionMeasure ;
    rdfs:label "Resourced provision measure shape"@en ;
    rdfs:comment "Both capacity and number on roll for a resourced provision unit must be non-negative integers. Number on roll must not exceed capacity."@en ;

    sh:property [
        sh:path epr:ResourcedProvisionCapacity ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
        sh:name "Resourced provision capacity"@en ;
        sh:message "Resourced provision capacity must be a non-negative integer."@en ;
    ] ;

    sh:property [
        sh:path epr:ResourcedProvisionPupilCount ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
        sh:name "Resourced provision number on roll"@en ;
        sh:message "Resourced provision number on roll must be a non-negative integer."@en ;
    ] .

epr:SenUnitMeasureShape
    a sh:NodeShape ;
    sh:targetClass epr:SenUnitMeasure ;
    rdfs:label "SEN unit measure shape"@en ;
    rdfs:comment "Both capacity and number on roll for a SEN unit must be non-negative integers."@en ;

    sh:property [
        sh:path epr:SenUnitCapacity ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
        sh:name "SEN unit capacity"@en ;
        sh:message "SEN unit capacity must be a non-negative integer."@en ;
    ] ;

    sh:property [
        sh:path epr:SenUnitPupilCount ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
        sh:name "SEN unit number on roll"@en ;
        sh:message "SEN unit number on roll must be a non-negative integer."@en ;
    ] .

epr:SpecialPupilMeasureShape
    a sh:NodeShape ;
    sh:targetClass epr:SpecialPupilMeasure ;
    rdfs:label "Special pupil measure shape"@en ;
    rdfs:comment "Counts of pupils with and without SEN statements or EHC plans must be non-negative integers."@en ;

    sh:property [
        sh:path epr:SpecialPupilsWithStatement ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
        sh:name "Special pupils with SEN statement or EHC plan"@en ;
        sh:message "Count of special pupils under a SEN statement or EHC plan must be a non-negative integer."@en ;
    ] ;

    sh:property [
        sh:path epr:SpecialPupilsWithoutStatement ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:maxCount 1 ;
        sh:name "Special pupils without SEN statement or EHC plan"@en ;
        sh:message "Count of special pupils not under a SEN statement or EHC plan must be a non-negative integer."@en ;
    ] .


#################################################################
# Statutory age range
#################################################################

epr:StatutoryAgeRangeShape
    a sh:NodeShape ;
    sh:targetClass epr:StatutoryAgeRange ;
    rdfs:label "Statutory age range shape"@en ;
    rdfs:comment "Lower and upper statutory ages must be non-negative integers within valid bounds, and the upper age must not be less than the lower age."@en ;

    sh:property [
        sh:path epr:AgeLow ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minInclusive 0 ;
        sh:maxInclusive 19 ;
        sh:maxCount 1 ;
        sh:name "Lower statutory age"@en ;
        sh:message "Lower statutory age must be a non-negative integer not greater than 19."@en ;
    ] ;

    sh:property [
        sh:path epr:AgeHigh ;
        sh:datatype xsd:nonNegativeInteger ;
        sh:minInclusive 0 ;
        sh:maxInclusive 25 ;
        sh:maxCount 1 ;
        sh:name "Upper statutory age"@en ;
        sh:message "Upper statutory age must be a non-negative integer not greater than 25."@en ;
    ] .


#################################################################
# Deferred - pending vocabulary data property definitions
#
# The following fields require data properties to be defined in
# establishment-details-vocabulary-skos.ttl before SHACL constraints
# can be expressed for their values:
#
# - PupilsEligibleForFreeSchoolMeals (count):
#     Requires epr:PupilsEligibleForFreeSchoolMeals data property.
#     Constraint: xsd:nonNegativeInteger.
#
# - PupilsEligibleForFreeSchoolMeals (percentage):
#     Requires epr:PercentagePupilsEligibleForFreeSchoolMeals data property.
#     Constraint: xsd:decimal; sh:minInclusive 0; sh:maxInclusive 100.
#
# These are documented here as pending items, not structural omissions.
#################################################################


