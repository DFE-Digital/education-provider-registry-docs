    rdfs:domain epr:EstablishmentClassification ;
    rdfs:range epr:ProviderType ;
    rdfs:comment "Cardinality: 0..1. Present for children's centres (types 47 and 48)."@en .

epro:hasCentreManager
    a owl:ObjectProperty ;
    rdfs:label "has centre manager"@en ;
    rdfs:domain epr:EstablishmentLocationAndContact ;
    rdfs:range epr:CentreManager ;
    rdfs:comment "Cardinality: 0..1. Present for children's centres (types 47 and 48). Distinct from hasHeadteacherOrPrincipal - children's centres show a centre manager role."@en .


#################################################################
# Object properties - establishment groups (v1.1)
#################################################################

epro:hasMembership
    a owl:ObjectProperty ;
    rdfs:label "has membership"@en ;
    rdfs:domain epr:Establishment ;
    rdfs:range epr:GroupMembership ;
    rdfs:comment "Cardinality: 0..*. An establishment may belong to one or more groups. Each membership is recorded as a GroupMembership instance."@en .

epro:memberOf
    a owl:ObjectProperty ;
    rdfs:label "member of"@en ;
    rdfs:domain epr:GroupMembership ;
    rdfs:range epr:EstablishmentGroup ;
    rdfs:comment "Cardinality: exactly 1. Each membership record links to one establishment group."@en .

epro:identifiedByGroupId
    a owl:ObjectProperty ;
    rdfs:label "identified by group identifier"@en ;
    rdfs:domain epr:EstablishmentGroup ;
    rdfs:range epr:GroupId ;
    rdfs:comment "Cardinality: 0..1. The business-facing GIAS group identifier for the group."@en .

epro:hasGroupUkprn
    a owl:ObjectProperty ;
    rdfs:label "has group UKPRN"@en ;
    rdfs:domain epr:EstablishmentGroup ;
    rdfs:range epr:GroupUkprn ;
    rdfs:comment "Cardinality: 0..1. UKPRN assigned to the group organisation by UKRLP."@en .

epro:hasGroupCompaniesHouseNumber
    a owl:ObjectProperty ;
    rdfs:label "has group Companies House number"@en ;
    rdfs:domain epr:EstablishmentGroup ;
    rdfs:range epr:CompaniesHouseNumber ;
    rdfs:comment "Cardinality: 0..1. Companies House registration for the group legal entity."@en .

epro:hasGroupRelationship
    a owl:ObjectProperty ;
    rdfs:label "has group relationship"@en ;
    rdfs:domain epr:EstablishmentGroup ;
    rdfs:range epr:GroupRelationship ;
    rdfs:comment "Cardinality: 0..*. A group may have one or more recorded relationships to other groups."@en .

epro:relatesTo
    a owl:ObjectProperty ;
    rdfs:label "relates to"@en ;
    rdfs:domain epr:GroupRelationship ;
    rdfs:range epr:EstablishmentGroup ;
    rdfs:comment "Cardinality: exactly 1. The other group in this group relationship."@en .

epro:classifiedByGroupRelationshipType
    a owl:ObjectProperty ;
    rdfs:label "classified by group relationship type"@en ;
    rdfs:domain epr:GroupRelationship ;
    rdfs:range epr:GroupRelationshipType ;
    rdfs:comment "Cardinality: exactly 1."@en .


#################################################################
# Object properties - governance (v1.2)
#################################################################

epro:hasGovernanceAppointment
    a owl:ObjectProperty ;
    rdfs:label "has governance appointment"@en ;
    rdfs:domain epr:Establishment ;
    rdfs:range epr:GovernanceAppointment ;
    rdfs:comment "Cardinality: 0..*. An establishment may have zero or more governance appointment records."@en .

epro:hasGroupGovernanceAppointment
    a owl:ObjectProperty ;
    rdfs:label "has group governance appointment"@en ;
    rdfs:domain epr:EstablishmentGroup ;
    rdfs:range epr:GovernanceAppointment ;
    rdfs:comment "Cardinality: 0..*. OWL domain is EstablishmentGroup - any group type could conceptually hold group-scoped governance appointments. Current GIAS data constraint (AcademyTrust only) is enforced in SHACL, not in this OWL domain declaration. Setting domain to AcademyTrust would cause OWL reasoners to incorrectly infer that any subject of this property is an AcademyTrust, which would be wrong if federation group governance is ever introduced."@en .

epro:hasGovernanceIdentifier
    a owl:ObjectProperty ;
    rdfs:label "has governance identifier"@en ;
    rdfs:domain epr:GovernanceAppointment ;
    rdfs:range epr:GovernanceIdentifier ;
    rdfs:comment "Cardinality: exactly 1. Every governance appointment has exactly one GID."@en .

epro:hasGovernanceRoleType
    a owl:ObjectProperty ;
    rdfs:label "has governance role type"@en ;
    rdfs:domain epr:GovernanceAppointment ;
    rdfs:range epr:GovernanceRoleType ;
    rdfs:comment "Cardinality: exactly 1."@en .

epro:hasGovernanceAppointmentDate
    a owl:ObjectProperty ;
    rdfs:label "has appointment date"@en ;
    rdfs:domain epr:GovernanceAppointment ;
    rdfs:range epr:GovernanceAppointmentDate ;
    rdfs:comment "Cardinality: 0..1."@en .

epro:hasGovernanceTermEndDate
    a owl:ObjectProperty ;
    rdfs:label "has term end date"@en ;
    rdfs:domain epr:GovernanceAppointment ;
    rdfs:range epr:GovernanceTermEndDate ;
    rdfs:comment "Cardinality: 0..1."@en .

epro:hasGovernanceAppointingBody
    a owl:ObjectProperty ;
    rdfs:label "has appointing body"@en ;
    rdfs:domain epr:GovernanceAppointment ;
    rdfs:range epr:GovernanceAppointingBody ;
    rdfs:comment "Cardinality: 0..1. Not typically populated for Accounting Officer and Chief Financial Officer roles."@en .

epro:appointmentOf
    a owl:ObjectProperty ;
    rdfs:label "appointment of"@en ;
    rdfs:domain epr:GovernanceAppointment ;
    rdfs:range epr:GovernancePerson ;
    rdfs:comment "Cardinality: 0..1. Links to the GovernancePerson when person matching has been completed. Absent for unmatched appointment stubs."@en .

epro:hasGovernancePersonIdentifier
    a owl:ObjectProperty ;
    rdfs:label "has governance person identifier"@en ;
    rdfs:domain epr:GovernancePerson ;
    rdfs:range epr:GovernancePersonIdentifier ;
    rdfs:comment "Cardinality: 0..*. May have multiple identifiers where previous-surname alias hashes are generated."@en .


#################################################################
# Classes - establishment type hierarchy
#
# Intermediate OWL classes grouping establishment types by their
# SHACL shape family. Leaf type classes (CommunitySchool etc.)
# are declared below in their own section.
#################################################################

epr:LaMaintainedSchool
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "LA maintained school"@en ;
    rdfs:comment "Any school maintained by a local authority: community schools, voluntary schools, foundation schools, community and foundation special schools, pupil referral units, and local authority nursery schools."@en .

epr:LaMainstreamSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMaintainedSchool ;
    rdfs:label "LA mainstream school"@en ;
    rdfs:comment "LA maintained mainstream schools: community school, voluntary aided school, voluntary controlled school, foundation school."@en .

epr:LaMaintainedSpecialSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMaintainedSchool ;
    rdfs:label "LA maintained special school"@en ;
    rdfs:comment "LA maintained special schools: community special school, foundation special school."@en .

epr:NonMaintainedAndIndependentSpecialSchool
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Non-maintained and independent special school"@en ;
    rdfs:comment "Non-maintained special schools and other independent special schools approved under section 342 of the Education Act 1996."@en .

epr:IndependentSchool
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Independent school"@en ;
    rdfs:comment "Independent schools: city technology colleges and other independent schools."@en .

epr:College
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "College"@en ;
    rdfs:comment "Further education establishments: further education colleges and sixth form centres."@en .

epr:Academy
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Academy"@en ;
    rdfs:comment "All academy types: mainstream, special, alternative provision, 16-19, and secure 16-19."@en .

epr:MainstreamAcademy
    a owl:Class ;
    rdfs:subClassOf epr:Academy ;
    rdfs:label "Mainstream academy"@en ;
    rdfs:comment "Mainstream academies: academy sponsor led and academy converter."@en .

epr:AcademySpecial
    a owl:Class ;
    rdfs:subClassOf epr:Academy ;
    rdfs:label "Academy special school"@en ;
    rdfs:comment "Academy special schools: academy special sponsor led and academy special converter."@en .

epr:AcademyAlternativeProvision
    a owl:Class ;
    rdfs:subClassOf epr:Academy ;
    rdfs:label "Academy alternative provision"@en ;
    rdfs:comment "Academy alternative provision establishments: academy alternative provision converter and academy alternative provision sponsor led."@en .

epr:Academy1619
    a owl:Class ;
    rdfs:subClassOf epr:Academy ;
    rdfs:label "Academy 16 to 19"@en ;
    rdfs:comment "Academy 16-19 establishments: academy 16-19 converter and academy 16 to 19 sponsor led."@en .

epr:FreeSchoolEstablishment
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Free school establishment"@en ;
    rdfs:comment "All free school types: mainstream free schools, free school special, free school alternative provision, and free school 16 to 19."@en .

epr:MainstreamFreeSchool
    a owl:Class ;
    rdfs:subClassOf epr:FreeSchoolEstablishment ;
    rdfs:label "Mainstream free school"@en ;
    rdfs:comment "Mainstream free schools: free school, university technical college, studio school."@en .

epr:ChildrensCentreEstablishment
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Children's centre establishment"@en ;
    rdfs:comment "Children's centres and children's centre linked sites."@en .


#################################################################
# Classes - establishment type leaf classes (v0.7)
#
# OWL class declarations for the 41 GIAS leaf establishment types,
# moved here from the taxonomy TTL. The taxonomy TTL retains the
# skos:Concept declarations and SKOS hierarchy (skos:broader).
# OWL 2 punning is preserved across both files.
#################################################################

# LA maintained mainstream schools
epr:CommunitySchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMainstreamSchool ;
    rdfs:label "Community school"@en ;
    rdfs:comment "A maintained school established under Part II of the School Standards and Framework Act 1998 in which the local authority employs all staff, owns the land and buildings, and acts as the admissions authority."@en .

epr:VoluntaryAidedSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMainstreamSchool ;
    rdfs:label "Voluntary aided school"@en ;
    rdfs:comment "A maintained school established under Part II of the School Standards and Framework Act 1998 in which the governing body is the employer and admissions authority, with land and buildings typically owned by a charitable foundation such as a diocese or religious body, which contributes towards capital costs."@en .

epr:VoluntaryControlledSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMainstreamSchool ;
    rdfs:label "Voluntary controlled school"@en ;
    rdfs:comment "A maintained school established under Part II of the School Standards and Framework Act 1998 in which the local authority is the employer and admissions authority; land and buildings are often owned by a voluntary or foundation body, but the school receives full local-authority funding without a capital contribution from the foundation."@en .

epr:FoundationSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMainstreamSchool ;
    rdfs:label "Foundation school"@en ;
    rdfs:comment "A maintained school established under Part II of the School Standards and Framework Act 1998 in which the governing body is the employer and admissions authority, with land and buildings that may be owned by the governing body or a charitable foundation rather than the local authority."@en .

# LA maintained special schools
epr:CommunitySpecialSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMaintainedSpecialSchool ;
    rdfs:label "Community special school"@en ;
    rdfs:comment "A local-authority-maintained special school established under Schedule 27 of the School Standards and Framework Act 1998 and the Education Act 1996, in which the local authority employs staff and is the admissions authority, catering wholly or mainly for children with special educational needs."@en .

epr:FoundationSpecialSchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMaintainedSpecialSchool ;
    rdfs:label "Foundation special school"@en ;
    rdfs:comment "A maintained special school established under Schedule 27 of the School Standards and Framework Act 1998 and the Education Act 1996, sharing the governance characteristics of a foundation school - including governing body as employer and admissions authority - while catering wholly or mainly for children with special educational needs."@en .

# LA maintained - other
epr:PupilReferralUnit
    a owl:Class ;
    rdfs:subClassOf epr:LaMaintainedSchool ;
    rdfs:label "Pupil referral unit"@en ;
    rdfs:comment "A local-authority establishment maintained under s.19 of the Education Act 1996 to provide education for children of compulsory school age who are excluded, persistently absent, ill or otherwise unable to attend a mainstream school."@en .

epr:LocalAuthorityNurserySchool
    a owl:Class ;
    rdfs:subClassOf epr:LaMaintainedSchool ;
    rdfs:label "Local authority nursery school"@en ;
    rdfs:comment "A nursery school maintained and funded by a local authority under the School Standards and Framework Act 1998, providing early years education for children below compulsory school age."@en .

# Non-maintained and independent special schools
epr:NonMaintainedSpecialSchool
    a owl:Class ;
    rdfs:subClassOf epr:NonMaintainedAndIndependentSpecialSchool ;
    rdfs:label "Non-maintained special school"@en ;
    rdfs:comment "A special school approved by the Secretary of State under s.342 of the Education Act 1996 that is not maintained by a local authority, operates on a not-for-profit basis, and caters wholly or mainly for children with special educational needs."@en .

epr:OtherIndependentSpecialSchool
    a owl:Class ;
    rdfs:subClassOf epr:NonMaintainedAndIndependentSpecialSchool ;
    rdfs:label "Other independent special school"@en ;
    rdfs:comment "An independent school that specialises in provision for pupils with special educational needs but is not approved by the Secretary of State under s.342 of the Education Act 1996 as a non-maintained special school."@en .

# Independent schools
epr:CityTechnologyCollege
    a owl:Class ;
    rdfs:subClassOf epr:IndependentSchool ;
    rdfs:label "City technology college"@en ;
    rdfs:comment "A state-funded independent school in an urban area, established under s.105 of the Education Reform Act 1988 with a curriculum emphasis on technology, science and practical skills, jointly funded by central government and private sponsors."@en .

epr:OtherIndependentSchool
    a owl:Class ;
    rdfs:subClassOf epr:IndependentSchool ;
    rdfs:label "Other independent school"@en ;
    rdfs:comment "An independent school registered with the Secretary of State that does not fall into a more specific independent-school category; it charges fees and is not maintained or funded by a local authority or the academy programme."@en .

# Colleges
epr:FurtherEducation
    a owl:Class ;
    rdfs:subClassOf epr:College ;
    rdfs:label "Further education"@en ;
    rdfs:comment "A general further education college or sixth-form college providing post-16 education and training, operating as an incorporated body under the Further and Higher Education Act 1992."@en .

epr:SixthFormCentre
    a owl:Class ;
    rdfs:subClassOf epr:College ;
    rdfs:label "Sixth form centre"@en ;
    rdfs:comment "A centre providing sixth-form education for students aged 16 to 18, operating under the Further and Higher Education Act 1992 and typically sharing facilities with or attached to a maintained school."@en .

# Universities and higher education
epr:HigherEducationInstitution
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Higher education institution"@en ;
    rdfs:comment "A university or other higher education provider recognised under the Further and Higher Education Act 1992 and the Higher Education Act 2004, offering degree-level and postgraduate qualifications."@en .

# Welsh establishments
epr:WelshEstablishment
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Welsh establishment"@en ;
    rdfs:comment "A school or other education provider in Wales that is registered with the Department for Education in GIAS but is governed by Welsh legislation enacted by Senedd Cymru, including the School Standards and Organisation (Wales) Act 2013."@en .

# Other types
epr:SecureUnits
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Secure units"@en ;
    rdfs:comment "Secure residential accommodation for children and young people that includes an educational function, recorded in GIAS for cross-departmental data purposes."@en .

epr:OffshoreSchools
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Offshore schools"@en ;
    rdfs:comment "A school operating in a Crown Dependency, British Overseas Territory or other non-mainland-UK geography that is registered with GIAS under Ministry of Defence or DfE arrangements."@en .

epr:ServiceChildrensEducation
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Service children's education"@en ;
    rdfs:comment "A school operated by the Service Children's Education (SCE) agency on behalf of the Ministry of Defence, providing education for the children of UK armed-forces personnel at bases in the United Kingdom and overseas."@en .

epr:MiscellaneousEstablishment
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Miscellaneous"@en ;
    rdfs:comment "A residual establishment type used in GIAS for records that cannot be classified under any more specific establishment-type category."@en .

epr:SpecialPost16Institution
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Special post 16 institution"@en ;
    rdfs:comment "A specialist institution approved under s.41 of the Children and Families Act 2014 to provide education or training for young people over 16 with special educational needs or disabilities, enabling placement via an education, health and care plan."@en .

epr:BritishSchoolsOverseas
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "British schools overseas"@en ;
    rdfs:comment "A school outside the United Kingdom that provides a British-style curriculum and was subject to voluntary inspection by Ofsted or an approved inspectorate under the Education (British Schools Abroad) Order 1999."@en .

epr:InstitutionFundedByOtherGovernmentDepartment
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Institution funded by other government department"@en ;
    rdfs:comment "An educational institution whose principal funding comes from a government department other than the Department for Education, and which is recorded in GIAS for cross-government data purposes."@en .

# Academies
epr:AcademySponsorLed
    a owl:Class ;
    rdfs:subClassOf epr:MainstreamAcademy ;
    rdfs:label "Academy sponsor led"@en ;
    rdfs:comment "An academy established through the sponsor-led route under the Academies Act 2010, typically replacing an underperforming school, with an approved sponsor providing governance and strategic leadership."@en .

epr:AcademySpecialSponsorLed
    a owl:Class ;
    rdfs:subClassOf epr:AcademySpecial ;
    rdfs:label "Academy special sponsor led"@en ;
    rdfs:comment "A new special academy established through the sponsor-led route under the Academies Act 2010, set up to cater for pupils with special educational needs where an approved sponsor provides strategic oversight."@en .

epr:AcademyConverter
    a owl:Class ;
    rdfs:subClassOf epr:MainstreamAcademy ;
    rdfs:label "Academy converter"@en ;
    rdfs:comment "A maintained school or other eligible institution that converted to academy status under the Academies Act 2010, entering into a funding agreement with the Secretary of State."@en .

epr:AcademyAlternativeProvisionConverter
    a owl:Class ;
    rdfs:subClassOf epr:AcademyAlternativeProvision ;
    rdfs:label "Academy alternative provision converter"@en ;
    rdfs:comment "An existing alternative provision establishment - such as a pupil referral unit - that converted to academy status under the Academies Act 2010 while continuing to provide education for pupils unable to attend mainstream school."@en .

epr:AcademyAlternativeProvisionSponsorLed
    a owl:Class ;
    rdfs:subClassOf epr:AcademyAlternativeProvision ;
    rdfs:label "Academy alternative provision sponsor led"@en ;
    rdfs:comment "A new alternative provision academy created through a sponsor-led route under the Academies Act 2010, established to provide education for pupils who cannot attend mainstream school."@en .

epr:AcademySpecialConverter
    a owl:Class ;
    rdfs:subClassOf epr:AcademySpecial ;
    rdfs:label "Academy special converter"@en ;
    rdfs:comment "A maintained special school that converted to academy status under the Academies Act 2010, continuing to cater wholly or mainly for pupils with special educational needs under a funding agreement with the Secretary of State."@en .

epr:Academy1619Converter
    a owl:Class ;
    rdfs:subClassOf epr:Academy1619 ;
    rdfs:label "Academy 16-19 converter"@en ;
    rdfs:comment "A 16-to-19 education provider - such as a sixth form college or school sixth form - that converted to academy status under the Academies Act 2010, entering into a funding agreement with the Secretary of State."@en .

epr:Academy16To19SponsorLed
    a owl:Class ;
    rdfs:subClassOf epr:Academy1619 ;
    rdfs:label "Academy 16 to 19 sponsor led"@en ;
    rdfs:comment "A new 16-to-19 academy established through the sponsor-led route under the Academies Act 2010, where an approved sponsor takes responsibility for the provision from the outset."@en .

epr:AcademySecure16To19
    a owl:Class ;
    rdfs:subClassOf epr:Academy ;
    rdfs:label "Academy secure 16 to 19"@en ;
    rdfs:comment "An academy providing education within secure residential accommodation for young people aged 16 to 19 who are subject to a custodial sentence or secure order."@en .

# Free schools
epr:FreeSchool
    a owl:Class ;
    rdfs:subClassOf epr:MainstreamFreeSchool ;
    rdfs:label "Free schools"@en ;
    rdfs:comment "A new state-funded school established as an academy under the Academies Act 2010 and Education Act 2011 through the free-school programme, allowing parents, teachers, charities or other groups to set up a school outside local-authority control."@en .

epr:FreeSchoolSpecial
    a owl:Class ;
    rdfs:subClassOf epr:FreeSchoolEstablishment ;
    rdfs:label "Free schools special"@en ;
    rdfs:comment "A free school established under the Academies Act 2010 to provide specialist education for pupils with special educational needs and disabilities."@en .

epr:FreeSchoolAlternativeProvision
    a owl:Class ;
    rdfs:subClassOf epr:FreeSchoolEstablishment ;
    rdfs:label "Free schools alternative provision"@en ;
    rdfs:comment "A free school established under the Academies Act 2010 to provide alternative provision for pupils who are unable to attend mainstream school due to exclusion, illness or other circumstances."@en .

epr:FreeSchool16To19
    a owl:Class ;
    rdfs:subClassOf epr:FreeSchoolEstablishment ;
    rdfs:label "Free schools 16 to 19"@en ;
    rdfs:comment "A free school established under the Academies Act 2010 that focuses exclusively on providing education and training to students aged 16 to 19."@en .

epr:UniversityTechnicalCollege
    a owl:Class ;
    rdfs:subClassOf epr:MainstreamFreeSchool ;
    rdfs:label "University technical college"@en ;
    rdfs:comment "An academy established under the Academies Act 2010 and Education Act 2011 through the free-school programme, for students aged 14 to 19, specialising in technical and vocational subjects with the active involvement of a university and employer sponsors."@en .

epr:StudioSchool
    a owl:Class ;
    rdfs:subClassOf epr:MainstreamFreeSchool ;
    rdfs:label "Studio schools"@en ;
    rdfs:comment "A small academy established under the Academies Act 2010 and Education Act 2011 through the free-school programme, typically for students aged 14 to 19, delivering mainstream qualifications through project-based and work-related learning with employer involvement."@en .

# Children's centres
epr:ChildrensCentre
    a owl:Class ;
    rdfs:subClassOf epr:ChildrensCentreEstablishment ;
    rdfs:label "Children's centre"@en ;
    rdfs:comment "A facility providing integrated early-childhood services - including early education, childcare, family support, health services and employment advice - established under the statutory framework of the Childcare Act 2006 and Children Act 2004."@en .

epr:ChildrensCentreLinkedSite
    a owl:Class ;
    rdfs:subClassOf epr:ChildrensCentreEstablishment ;
    rdfs:label "Children's centre linked site"@en ;
    rdfs:comment "A site that delivers some early childhood services on behalf of a named children's centre, having previously been registered as a standalone children's centre under the Childcare Act 2006 framework."@en .

# Online providers
epr:OnlineProvider
    a owl:Class ;
    rdfs:subClassOf epr:Establishment ;
    rdfs:label "Online provider"@en ;
    rdfs:comment "A provider that delivers full-time education entirely online to pupils of compulsory school age, recognised under the DfE online education accreditation scheme."@en .


#################################################################
# Classes - establishment groups (v1.1)
#################################################################

epr:EstablishmentGroup
    a owl:Class ;
    rdfs:label "Establishment group"@en ;
    rdfs:comment "An organisation or governance structure to which one or more establishments belong. Covers academy trusts, federations, school sponsors and children's centre groups. Distinct from the accountability relationship, which records legal/governance responsibility. Academy trusts are both establishment groups and accountability bodies - see epr:AcademyTrust."@en .

epr:MultiAcademyTrust
    a owl:Class ;
    rdfs:subClassOf epr:AcademyTrust ;
    rdfs:label "Multi-academy trust"@en ;
    rdfs:comment "A single legal academy-trust entity operating two or more academies, free schools, UTCs or studio schools. It has a master funding agreement with the Secretary of State and a supplemental funding agreement for each individual academy. Incorporated under the Companies Act 2006. Governed by a board of trustees. Source: GOV.UK academy trust governance guide."@en .

epr:SecureSingleAcademyTrust
    a owl:Class ;
    rdfs:subClassOf epr:SingleAcademyTrust ;
    rdfs:label "Secure single-academy trust"@en ;
    rdfs:comment "A single-academy trust operating a secure 16-to-19 academy providing education within secure residential accommodation for young people aged 16 to 19 subject to a custodial sentence or secure order."@en .

epr:Federation
    a owl:Class ;
    rdfs:subClassOf epr:EstablishmentGroup ;
    rdfs:label "Federation"@en ;
    rdfs:comment "A statutory arrangement in which two or more maintained schools, including maintained nursery schools, share a single federated governing body. Each member school retains its own URN, establishment number, admissions arrangements and Ofsted inspection identity. Some governance and funding arrangements may be shared or pooled under federation rules. Applicable only to maintained schools. Source: School Governance (Federations) Regulations 2012."@en .

epr:SchoolSponsor
    a owl:Class ;
    rdfs:subClassOf epr:EstablishmentGroup ;
    rdfs:label "School sponsor"@en ;
    rdfs:comment "A body approved by the Secretary of State to sponsor one or more sponsor-led academies or free schools. Supports governance, leadership and educational improvement. Source: Academies Act 2010."@en .

epr:ChildrensCentreGroup
    a owl:Class ;
    rdfs:subClassOf epr:EstablishmentGroup ;
    rdfs:label "Children's centres group"@en ;
    rdfs:comment "An operational cluster of children's centres with a lead-centre arrangement."@en .

epr:ChildrensCentreCollaboration
    a owl:Class ;
    rdfs:subClassOf epr:EstablishmentGroup ;
    rdfs:label "Children's centres collaboration"@en ;
    rdfs:comment "A cross-group collaboration arrangement between children's centres."@en .

epr:GenericTrust
    a owl:Class ;
    rdfs:subClassOf epr:EstablishmentGroup ;
    rdfs:label "Trust"@en ;
    rdfs:comment "A generic trust group type (EstablishmentGroupType code 02). Distinct from AcademyTrust. Rarely used in current data; retained for completeness."@en .

epr:GroupMembership
    a owl:Class ;
    rdfs:label "Group membership"@en ;
    rdfs:comment "A dated record of an establishment's membership of an establishment group, trust, federation, sponsor arrangement or children's centre collaboration. Maps to GroupLink in the current GIAS schema. An establishment may have membership in more than one group simultaneously."@en .

epr:GroupRelationship
    a owl:Class ;
    rdfs:label "Group relationship"@en ;
    rdfs:comment "A recorded relationship between two establishment groups, for example where a single-academy trust is the predecessor to a newly formed multi-academy trust. Maps to GroupRelationsLink."@en .

epr:GroupRelationshipType
    a owl:Class ;
    rdfs:label "Group relationship type"@en ;
    rdfs:comment "The classification of a group-to-group relationship, for example predecessor SAT or successor MAT."@en .

epr:GroupId
    a owl:Class ;
    rdfs:label "Group identifier"@en ;
    rdfs:comment "The business-facing GIAS group identifier, distinct from the internal surrogate key."@en .

epr:GroupUkprn
    a owl:Class ;
    rdfs:label "Group UKPRN"@en ;
    rdfs:comment "A UKRLP provider reference number assigned to the group organisation. Sourced from UKRLP by matching on Companies House number."@en .


#################################################################
# Classes - governance (v1.2)
#################################################################

epr:GovernanceAppointment
    a owl:Class ;
    rdfs:label "Governance appointment"@en ;
    rdfs:comment "A record of one named person holding one governance role at one establishment or group during a defined period. Identified by the GIAS Governance Identifier (GID). Carries the role type, appointment date, optional term-end date and appointing body. Personal-data-carrying class: contains person-name fields (Title, Forename 1, Forename 2, Surname)."@en ;
    dcterms:accessRights "Personal data - access controls required. Person-name fields are encrypted at the logical model layer."@en .

epr:GovernanceIdentifier
    a owl:Class ;
    rdfs:label "Governance identifier (GID)"@en ;
    rdfs:comment "The GIAS-assigned identifier for a governance appointment record. Unique per governance row. Not a person identifier - one physical person may have multiple GIDs across different roles and establishments."@en .

epr:GovernanceRoleType
    a owl:Class ;
    rdfs:label "Governance role type"@en ;
    rdfs:comment "The classification of the governance role held. Closed enumeration of 22 values: 20 from the GIAS governance extract, plus headteacher ex-officio governor (SI 2012/1034) and associate member (SI 2013/1624) from the maintained schools governance guide."@en .

epr:GovernanceAppointmentDate
    a owl:Class ;
    rdfs:label "Appointment date"@en ;
    rdfs:comment "The date on which the governance appointment took effect."@en .

epr:GovernanceTermEndDate
    a owl:Class ;
    rdfs:label "Term end date"@en ;
    rdfs:comment "The date on which the governance appointment ended or is due to end. Optional - absence does not confirm a current appointment without business-rule validation. Structural absence for Member role is expected."@en .

epr:GovernanceAppointingBody
    a owl:Class ;
    rdfs:label "Appointing body"@en ;
    rdfs:comment "The body or mechanism responsible for appointing the governor, trustee or member. Closed enumeration of 18 values derived from the GIAS governance extract Appointing body field. RSC value retired."@en .

epr:GovernancePerson
    a owl:Class ;
    rdfs:label "Governance person"@en ;
    rdfs:comment "A named individual who holds or has held a formal governance role at an establishment, establishment group or trust. Covers governors, trustees, members, local governors, accounting officers, chief financial officers and governance professionals. One GovernancePerson may be linked from multiple GovernanceAppointment records. Personal-data-carrying class - requires access-control annotation."@en ;
    dcterms:accessRights "Personal data - access controls required. Contains GovernancePersonIdentifier (pseudonymous hash derived from date of birth, surname and forename1). Raw date of birth not stored in EPR."@en .

epr:GovernancePersonIdentifier
    a owl:Class ;
    rdfs:label "Governance person identifier"@en ;
    rdfs:comment "A pseudonymous identifier for a GovernancePerson, derived by hashing normalised date of birth, surname and forename1. Deterministic but not reversible to recover the raw date of birth. Previous-surname alias hashes generated where StaffRecordEnc.prevSurname is populated. Pseudonymous personal data under UK GDPR."@en .


#################################################################
# Named individuals - closed enumeration values (v0.8, v1.0)
#
# Classification values for closed, stable enumerations that
# carry semantic weight. Declared as owl:NamedIndividual so they
# appear in WebVOWL and support OWL reasoning.
#
# Open-ended value sets (ReligiousCharacter, ReligiousEthos,
# TypeOfSenProvision, establishment type codes) remain as
# skos:Concept in the vocabulary TTL only.
#

# Identifier role (2 values, v1.0)
epr:CurrentIdentifierRole
    a owl:NamedIndividual, epr:IdentifierRole ;
    rdfs:label "Current"@en ;
    rdfs:comment "The scoped establishment number is the establishment's active current identity."@en .

epr:PreviousIdentifierRole
    a owl:NamedIndividual, epr:IdentifierRole ;
    rdfs:label "Previous"@en ;
    rdfs:comment "The scoped establishment number is a previous identity, retained for search continuity and lifecycle traceability."@en .

# Group relationship type (2 values, v1.1)
epr:SuccessorMultiAcademyTrust
    a owl:NamedIndividual, epr:GroupRelationshipType ;
    rdfs:label "Successor MAT"@en ;
    rdfs:comment "A group relationship type value indicating that the group is the multi-academy trust formed when a single-academy trust expanded or merged."@en .

epr:PredecessorSingleAcademyTrust
    a owl:NamedIndividual, epr:GroupRelationshipType ;
    rdfs:label "Predecessor SAT"@en ;
    rdfs:comment "A group relationship type value indicating that the group is the single-academy trust that preceded the formation of a multi-academy trust."@en .
# The same epr: URIs also carry skos:Concept in the vocabulary
# TTL - valid OWL 2 punning.
#################################################################

# Establishment status (4 values)
epr:OpenStatus
    a owl:NamedIndividual, epr:EstablishmentStatus ;
    rdfs:label "Open"@en ;
    rdfs:comment "The establishment is currently open and operating. This is the normal status for an active registered establishment."@en .

epr:ClosedStatus
    a owl:NamedIndividual, epr:EstablishmentStatus ;
    rdfs:label "Closed"@en ;
    rdfs:comment "The establishment has closed and is no longer operating. The record is retained in GIAS for historical reference, along with the closed date and reason for closure."@en .

epr:OpenProposedToCloseStatus
    a owl:NamedIndividual, epr:EstablishmentStatus ;
    rdfs:label "Open, but proposed to close"@en ;
    rdfs:comment "The establishment is currently open but has been formally proposed for closure through statutory proposals under the School Standards and Framework Act 1998 (schedule 6) or the Education and Inspections Act 2006. The closure has not yet taken effect."@en .

epr:ProposedToOpenStatus
    a owl:NamedIndividual, epr:EstablishmentStatus ;
    rdfs:label "Proposed to open"@en ;
    rdfs:comment "The establishment has been approved but has not yet opened. Academy and free school proposals use this status between the signing of the funding agreement and the establishment's first day of operation."@en .

# Education phase (8 values)
epr:NurseryPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "Nursery"@en ;
    rdfs:comment "An education phase for establishments providing early years education to children below compulsory school age, typically ages 3 to 4."@en .

epr:PrimaryPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "Primary"@en ;
    rdfs:comment "An education phase for establishments providing primary education, broadly covering ages 4 or 5 to 11, within the compulsory school age range defined by the Education Act 1996 s.8."@en .

epr:MiddlePhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "Middle deemed primary"@en ;
    rdfs:comment "An education phase assigned to a middle school where the Secretary of State has determined it should be treated as a primary school, typically because the majority of its age range falls within primary years."@en .

epr:MiddleDeemedSecondaryPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "Middle deemed secondary"@en ;
    rdfs:comment "An education phase assigned to a middle school where the Secretary of State has determined it should be treated as a secondary school, typically because the majority of its age range falls within secondary years."@en .

epr:SecondaryPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "Secondary"@en ;
    rdfs:comment "An education phase for establishments providing secondary education, broadly covering ages 11 to 16, and up to 18 where sixth-form provision is included, within the compulsory school age range defined by the Education Act 1996 s.8."@en .

epr:AllThroughPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "All-through"@en ;
    rdfs:comment "An education phase covering the full compulsory school age range within a single establishment, spanning both primary and secondary years (typically ages 4 or 5 to 16 or 18)."@en .

epr:SixteenToNineteenPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "16 to 19"@en ;
    rdfs:comment "An education phase for establishments providing post-16 education and training to young people aged 16 to 19, including sixth-form colleges and studio schools."@en .

epr:NotApplicableEducationPhase
    a owl:NamedIndividual, epr:EducationPhase ;
    rdfs:label "Not applicable (education phase)"@en ;
    rdfs:comment "A classification value indicating that the education phase field is not applicable to this type of establishment."@en .

# Admissions policy (3 values)
epr:SelectiveAdmissions
    a owl:NamedIndividual, epr:AdmissionsPolicy ;
    rdfs:label "Selective"@en ;
    rdfs:comment "An admissions-policy value indicating that the school selects all or some pupils by reference to academic ability or aptitude."@en .

epr:NonSelectiveAdmissions
    a owl:NamedIndividual, epr:AdmissionsPolicy ;
    rdfs:label "Non-selective"@en ;
    rdfs:comment "An admissions-policy value indicating that the school does not allocate places through academic selection tests or criteria."@en .

epr:NotApplicableAdmissionsPolicy
    a owl:NamedIndividual, epr:AdmissionsPolicy ;
    rdfs:label "Not applicable (admissions policy)"@en ;
    rdfs:comment "A classification value indicating that an admissions policy classification does not apply to this type of establishment."@en .

# Gender of entry (4 values)
epr:BoysOnlyGenderEntry
    a owl:NamedIndividual, epr:GenderOfEntry ;
    rdfs:label "Boys"@en ;
    rdfs:comment "A gender-of-entry value indicating that the establishment admits boys only."@en .

epr:GirlsOnlyGenderEntry
    a owl:NamedIndividual, epr:GenderOfEntry ;
    rdfs:label "Girls"@en ;
    rdfs:comment "A gender-of-entry value indicating that the establishment admits girls only."@en .

epr:MixedGenderEntry
    a owl:NamedIndividual, epr:GenderOfEntry ;
    rdfs:label "Mixed"@en ;
    rdfs:comment "A gender-of-entry value indicating that the establishment admits both boys and girls without restriction on grounds of sex."@en .

epr:NotApplicableGenderOfEntry
    a owl:NamedIndividual, epr:GenderOfEntry ;
    rdfs:label "Not applicable (gender of entry)"@en ;
    rdfs:comment "A classification value indicating that a gender-of-entry classification does not apply to this type of establishment."@en .

# Boarding provision (3 values)
epr:BoardingSchool
    a owl:NamedIndividual, epr:BoardingProvision ;
    rdfs:label "Boarding school"@en ;
    rdfs:comment "A boarding-provision value indicating that the establishment is registered and operates principally as a boarding school, where pupils reside during term time."@en .

epr:HasBoarders
    a owl:NamedIndividual, epr:BoardingProvision ;
    rdfs:label "Has boarders"@en ;
    rdfs:comment "A boarding-provision value indicating that the establishment accommodates some pupils as boarders, but is not primarily classified as a boarding school."@en .

epr:NoBoarders
    a owl:NamedIndividual, epr:BoardingProvision ;
    rdfs:label "No boarders"@en ;
    rdfs:comment "A boarding-provision value indicating that the establishment does not accommodate any pupils as boarders."@en .

# Nursery provision (3 values)
epr:HasNurseryClasses
    a owl:NamedIndividual, epr:NurseryProvision ;
    rdfs:label "Has nursery classes"@en ;
    rdfs:comment "A nursery-provision value indicating that the establishment operates one or more nursery classes for children below compulsory school age."@en .

epr:NoNurseryClasses
    a owl:NamedIndividual, epr:NurseryProvision ;
    rdfs:label "No nursery classes"@en ;
    rdfs:comment "A nursery-provision value indicating that the establishment does not operate any nursery classes."@en .

epr:NotApplicableNurseryProvision
    a owl:NamedIndividual, epr:NurseryProvision ;
    rdfs:label "Not applicable (nursery provision)"@en ;
    rdfs:comment "A classification value indicating that a nursery provision classification does not apply to this type of establishment."@en .

# Sixth-form provision (3 values)
epr:HasSixthForm
    a owl:NamedIndividual, epr:SixthFormProvision ;
    rdfs:label "Has a sixth form"@en ;
    rdfs:comment "A sixth-form-provision value indicating that the establishment provides post-16 education as a sixth form, catering to pupils typically in Years 12 and 13."@en .

epr:NoSixthForm
    a owl:NamedIndividual, epr:SixthFormProvision ;
    rdfs:label "Does not have a sixth form"@en ;
    rdfs:comment "A sixth-form-provision value indicating that the establishment does not provide a sixth form."@en .

epr:NotApplicableSixthFormProvision
    a owl:NamedIndividual, epr:SixthFormProvision ;
    rdfs:label "Not applicable (sixth-form provision)"@en ;
    rdfs:comment "A classification value indicating that a sixth-form provision classification does not apply to this type of establishment."@en .

# Special-class provision (3 values)
epr:HasSpecialClasses
    a owl:NamedIndividual, epr:SpecialClassProvision ;
    rdfs:label "Has special classes"@en ;
    rdfs:comment "A special-class-provision value indicating that the establishment provides one or more specially resourced classes or units for pupils with special educational needs."@en .

epr:NoSpecialClasses
    a owl:NamedIndividual, epr:SpecialClassProvision ;
    rdfs:label "No special classes"@en ;
    rdfs:comment "A special-class-provision value indicating that the establishment does not provide any specially resourced classes or units for pupils with special educational needs."@en .

epr:NotApplicableSpecialClassProvision
    a owl:NamedIndividual, epr:SpecialClassProvision ;
    rdfs:label "Not applicable (special-class provision)"@en ;
    rdfs:comment "A classification value indicating that a special-class provision classification does not apply to this type of establishment."@en .

# Governance role type (22 values, v1.2)
epr:GovernorRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Governor"@en ;
    rdfs:comment "A governance role in a maintained school governing body."@en .

epr:ChairOfGovernorsRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Chair of governors"@en ;
    rdfs:comment "The chair of a maintained school governing body."@en .

epr:HeadteacherExOfficioGovernorRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Headteacher (ex-officio governor)"@en ;
    rdfs:comment "Headteacher of a maintained school holding a governor role by virtue of their office, as defined in the School Governance (Constitution) (England) Regulations 2012 (SI 2012/1034). Modelled from the maintained schools governance guide; not separately enumerated in the GIAS governance extract."@en .

epr:AssociateMemberRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Associate member"@en ;
    rdfs:comment "A non-voting participant in a maintained school governing body or committee, as defined in the School Governance (Roles, Procedures and Allowances) (England) Regulations 2013 (SI 2013/1624)."@en .

epr:LocalGovernorRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Local governor"@en ;
    rdfs:comment "A member of a local governing body for an individual academy within a multi-academy trust."@en .

epr:ChairOfLocalGoverningBodyRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Chair of local governing body"@en ;
    rdfs:comment "The chair of a local governing body for an individual academy within a multi-academy trust."@en .

epr:TrusteeRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Trustee"@en ;
    rdfs:comment "A trustee of an academy trust board."@en .

epr:ChairOfTrusteesRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Chair of trustees"@en ;
    rdfs:comment "The chair of an academy trust board of trustees."@en .

epr:MemberRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Member"@en ;
    rdfs:comment "A member of an academy trust, holding a constitutional oversight role above the trustee board. Absence of term-end date is structurally expected for this role."@en .

epr:AccountingOfficerRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Accounting officer"@en ;
    rdfs:comment "The accounting officer of an academy trust, responsible to Parliament for the regularity and propriety of public expenditure."@en .

epr:ChiefFinancialOfficerRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Chief financial officer"@en ;
    rdfs:comment "The chief financial officer of an academy trust."@en .

epr:SharedLocalGovernorEstablishmentRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Shared local governor (establishment)"@en ;
    rdfs:comment "A local governor exercising a shared governance role recorded at establishment level in the GIAS governance extract. Modelled as group-scoped in EPR."@en .

epr:SharedLocalGovernorGroupRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Shared local governor (group)"@en ;
    rdfs:comment "A local governor exercising a shared governance role recorded at group level in the GIAS governance extract."@en .

epr:SharedChairOfLocalGoverningBodyEstablishmentRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Shared chair of local governing body (establishment)"@en ;
    rdfs:comment "A shared chair of local governing body recorded at establishment level in the GIAS governance extract. Modelled as group-scoped in EPR."@en .

epr:SharedChairOfLocalGoverningBodyGroupRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Shared chair of local governing body (group)"@en ;
    rdfs:comment "A shared chair of local governing body recorded at group level in the GIAS governance extract."@en .

epr:GovernanceProfessionalLaMaintainedSchoolRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Governance professional - local authority maintained school"@en ;
    rdfs:comment "A governance professional supporting a local authority maintained school governing body."@en .

epr:LocalGovernanceProfessionalIndividualAcademyRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Local governance professional - individual academy or free school"@en ;
    rdfs:comment "A governance professional supporting the local governing body of an individual academy or free school."@en .

epr:GovernanceProfessionalSatRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Governance professional - single-academy trust (SAT)"@en ;
    rdfs:comment "A governance professional supporting a single-academy trust board."@en .

epr:GovernanceProfessionalMatRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Governance professional - multi-academy trust (MAT)"@en ;
    rdfs:comment "A governance professional supporting a multi-academy trust board."@en .

epr:GovernanceProfessionalFederationRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Governance professional - federation"@en ;
    rdfs:comment "A governance professional supporting a federated governing body."@en .

epr:SharedGovernanceProfessionalEstablishmentRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Shared governance professional (establishment)"@en ;
    rdfs:comment "A shared governance professional recorded at establishment level in the GIAS governance extract. Modelled as group-scoped in EPR."@en .

epr:SharedGovernanceProfessionalGroupRole
    a owl:NamedIndividual, epr:GovernanceRoleType ;
    rdfs:label "Shared governance professional (group)"@en ;
    rdfs:comment "A shared governance professional recorded at group level in the GIAS governance extract."@en .

# Governance appointing body (18 values, v1.2)
epr:AppointedByGoverningBoard
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Appointed by GB/board"@en ;
    rdfs:comment "Appointed by the governing board."@en .

epr:AppointedByFoundationOrTrust
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Appointed by foundation/Trust"@en ;
    rdfs:comment "Appointed by a foundation body or trust."@en .

epr:ElectedByParents
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Elected by parents"@en ;
    rdfs:comment "Elected by the parent body under the School Governance (Constitution) (England) Regulations 2012."@en .

epr:ElectedBySchoolStaff
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Elected by school staff"@en ;
    rdfs:comment "Elected by school staff under the School Governance (Constitution) (England) Regulations 2012."@en .

epr:ExOfficioHeadteacher
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Ex-officio by virtue of office as headteacher/principal"@en ;
    rdfs:comment "Appointed ex-officio by virtue of holding the headteacher or principal role."@en .

epr:AppointedByAcademyMembers
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Appointed by academy members"@en ;
    rdfs:comment "Appointed by the academy trust members."@en .

epr:AppointingBodyNotApplicable
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "N/A"@en ;
    rdfs:comment "Appointing body is not applicable for this governance role."@en .

epr:ParentAppointedByGbDueToNoElection
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Parent appointed by GB/board due to no election candidates"@en ;
    rdfs:comment "Parent governor appointed by the governing board due to insufficient election candidates."@en .

epr:FoundationOrSponsorMembers
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Foundation/sponsor members"@en ;
    rdfs:comment "Foundation or sponsor members of the governing body."@en .

epr:NominatedByLaAppointedByGb
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Nominated by LA and appointed by GB"@en ;
    rdfs:comment "Nominated by the local authority and appointed by the governing board."@en .

epr:ExOfficioFoundationGovernor
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Ex-officio foundation governor (appointed by foundation by virtue of the office they hold)"@en ;
    rdfs:comment "Foundation governor appointed ex-officio by virtue of another office held within the foundation body."@en .

epr:AppointedByTrustees
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Appointed by trustees"@en ;
    rdfs:comment "Appointed by the board of trustees."@en .

epr:AppointedByLa
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Appointed by LA"@en ;
    rdfs:comment "Appointed by the local authority."@en .

epr:PersonsAppointedByFoundationOrSponsor
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Persons who are appointed by the foundation body or sponsor (if applicable)"@en ;
    rdfs:comment "Persons appointed by the foundation body or sponsor."@en .

epr:OriginalSignatoryMembers
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Original (signatory) members"@en ;
    rdfs:comment "Original signatory members of the academy trust per the model articles of association."@en .

epr:NominatedByOtherBodyAppointedByGb
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Nominated by other body and appointed by GB"@en ;
    rdfs:comment "Nominated by another body and appointed by the governing board."@en .

epr:AdditionalMembersAppointedByMembers
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Any additional members appointed by the members of the academy trust"@en ;
    rdfs:comment "Additional members appointed by existing members of the academy trust."@en .

epr:InterimExecutiveBoard
    a owl:NamedIndividual, epr:GovernanceAppointingBody ;
    rdfs:label "Interim Executive Board"@en ;
    rdfs:comment "An Interim Executive Board appointed by the Regional Schools Commissioner or successor body."@en .


