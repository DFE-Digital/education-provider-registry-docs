@prefix epr:     <https://dfe-digital.github.io/education-provider-registry-docs/vocabulary/> .
@prefix epro:    <https://dfe-digital.github.io/education-provider-registry-docs/ontology/> .
@prefix owl:     <http://www.w3.org/2002/07/owl#> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix skos:    <http://www.w3.org/2004/02/skos/core#> .
@prefix vann:    <http://purl.org/vocab/vann/> .

# GIAS 2.0 Establishment Details Conceptual Model
#
# Scope: this OWL ontology expresses the first conceptual model slice for the
# Education Provider Registry data prototype. It covers the public GIAS
# Establishment Details view for the currently modelled establishment examples.
#
# It declares classes and object properties that correspond directly to the
# entities and relationships shown in the Establishment Details ER diagrams.
# Class IRIs reuse the shared epr: namespace so that vocabulary concepts and
# ontology classes are the same resolvable URI.
#
#
# It sits alongside the vocabulary and taxonomy:
#   establishment-details-vocabulary-skos.ttl
#   establishment-details-taxonomy-skos.ttl


#################################################################
# Ontology declaration
#################################################################

epro:establishmentDetailsConceptualModel
    a owl:Ontology ;
    dcterms:title "GIAS 2.0 Establishment Details Conceptual Model"@en ;
    dcterms:description "OWL 2 conceptual model for the Establishment Details slice of the Education Provider Registry. Declares classes and object properties for the entities and relationships in the Establishment Details ER diagrams."@en ;
    rdfs:comment "This ontology defines the classes and object properties for the Establishment Details slice of the Education Provider Registry (EPR) data model. It covers establishment identity and identifiers, lifecycle, classification, accountability, education provision, capacity measures, faith context, SEN and resourced provision, and external references. Class IRIs are shared with the SKOS vocabulary so that vocabulary concepts and ontology classes resolve to the same URI. Object properties are defined in the /ontology/ namespace."@en ;
    dcterms:created "2026-06-18"^^xsd:date ;
    dcterms:modified "2026-06-24"^^xsd:date ;
    dcterms:publisher "Department for Education"@en ;
    dcterms:license <https://www.nationalarchives.gov.uk/doc/open-government-licence/version/3/> ;
    owl:versionInfo "1.2" ;
    vann:preferredNamespacePrefix "epro" ;
    vann:preferredNamespaceUri "https://dfe-digital.github.io/education-provider-registry-docs/ontology/"^^xsd:anyURI ;
    rdfs:seeAlso <https://dfe-digital.github.io/education-provider-registry-docs/vocabulary/> ;
    rdfs:seeAlso <https://dfe-digital.github.io/education-provider-registry-docs/taxonomy/> ;
    rdfs:seeAlso <https://dfe-digital.github.io/education-provider-registry-docs/shapes/> ;
    rdfs:seeAlso <https://dfe-digital.github.io/education-provider-registry-docs/shapes/data-quality/> ;
    rdfs:comment "v0.2: per-type field-applicability rules added as SHACL shapes in establishment-details-shacl.ttl. Accountability relationship rules (which types require LA, academy trust or proprietor) are now expressed in those shapes rather than as open questions."@en ;
    rdfs:comment "v0.4: field-coverage additions - classes and properties for Ofsted inspection record, PRU operational record, accreditation record (online providers), provider type, manager, academy sponsor SHACL modelling. Ontology already had faith-context classes (ReligiousCharacter, ReligiousEthos, Diocese) and SpecialClassProvision. New additions: OfstedInspectionRecord, PupilReferralUnitOperationalRecord, AccreditationRecord, ProviderType, Manager."@en ;
    rdfs:comment "v0.5: establishment type class hierarchy added. Each GIAS establishment type is now an OWL class subtype of epr:Establishment, via intermediate group classes (LaMaintainedSchool, Academy, FreeSchoolEstablishment etc.). Intermediate classes defined here; leaf type classes enriched with owl:Class and rdfs:subClassOf in the taxonomy TTL using OWL 2 punning."@en ;
    rdfs:comment "v0.7: leaf type OWL class declarations moved from the taxonomy TTL into this ontology TTL. The taxonomy TTL is now pure SKOS (skos:Concept, skos:broader etc.). OWL punning is preserved - the same epr: URIs remain valid SKOS concepts in the taxonomy. WIDOCO now receives only this ontology TTL, eliminating the skos:Concept hub node from the WebVOWL graph."@en ;
    rdfs:comment "v0.8: owl:NamedIndividual declarations added for 8 closed enumerations (31 individuals total): EstablishmentStatus, EducationPhase, AdmissionsPolicy, GenderOfEntry, BoardingProvision, NurseryProvision, SixthFormProvision, SpecialClassProvision. Open-ended value sets (ReligiousCharacter, ReligiousEthos, TypeOfSenProvision) remain as skos:Concept in the vocabulary TTL only."@en ;
    rdfs:comment "v0.9: PupilReferralUnitOperationalRecord and AccreditationRecord property declarations converted from owl:DatatypeProperty (xsd:boolean/integer/date/string/anyURI ranges) to owl:ObjectProperty with named epr: range classes (15 new classes). Ontology is now entirely ObjectProperty - no DatatypeProperty declarations remain."@en ;
    rdfs:comment "v1.0: Identifier modelling tightened. (1) hasUprn domain moved from EstablishmentIdentity to MainAddress. (2) FeHeIdentifier added as OWL class with hasFeHeIdentifier property. (3) hasEstablishmentNumber replaced by LocalAuthorityScopedEstablishmentNumber with hasLocalAuthorityContext, hasEstablishmentNumberValue and hasIdentifierRole components. (4) IdentifierRole added with CurrentIdentifierRole and PreviousIdentifierRole named individuals. (5) EstablishmentNumber value SHACL (1-9999) and UKPRN structural max-1 added."@en ;
    rdfs:comment "v1.1: Establishment group model added. New abstract group superclass EstablishmentGroup; MultiAcademyTrust (subClassOf AcademyTrust), SecureSingleAcademyTrust (subClassOf SingleAcademyTrust), Federation, SchoolSponsor, ChildrensCentreGroup, ChildrensCentreCollaboration, GenericTrust (group org classes); GroupMembership, GroupRelationship, GroupRelationshipType, GroupId, GroupUkprn. AcademyTrust gains dual inheritance: rdfs:subClassOf EstablishmentGroup in addition to existing accountability hierarchy. Named individuals SuccessorMultiAcademyTrust and PredecessorSingleAcademyTrust added for GroupRelationshipType."@en ;
    rdfs:comment "v1.2: Governance model added. 8 new OWL classes: GovernanceAppointment, GovernanceIdentifier, GovernanceRoleType, GovernanceAppointmentDate, GovernanceTermEndDate, GovernanceAppointingBody, GovernancePerson, GovernancePersonIdentifier. 9 new object properties: hasGovernanceAppointment (domain Establishment), hasGroupGovernanceAppointment (domain EstablishmentGroup; AcademyTrust-only enforced in SHACL), hasGovernanceIdentifier, hasGovernanceRoleType, hasGovernanceAppointmentDate, hasGovernanceTermEndDate, hasGovernanceAppointingBody, appointmentOf, hasGovernancePersonIdentifier. 22 named individuals for GovernanceRoleType; 18 for GovernanceAppointingBody. GovernanceAppointment and GovernancePerson annotated with dcterms:accessRights as personal-data-carrying classes."@en ;
    rdfs:comment "v0.6: ontology class local names aligned with vocabulary source of truth. Renames: ContactAndLocation -> EstablishmentLocationAndContact, PostalAddress -> MainAddress, WebsiteUrl -> Website, Manager -> CentreManager, Section41ApprovalStatus -> Section41Approval. Vocabulary entries added for all 14 intermediate OWL classes and for grouping container classes (ResourcedProvisionMeasure, SenUnitMeasure, SpecialPupilMeasure, OfstedInspectionRecord, AccreditationRecord, PupilReferralUnitOperationalRecord)."@en ;
    epr:status "Provisional"@en .


#################################################################
# Classes - core
#################################################################

epr:Establishment
    a owl:Class ;
    rdfs:label "Establishment"@en ;
    rdfs:comment "The central concept. A single education provider registered with GIAS."@en .

epr:EstablishmentDetails
    a owl:Class ;
    rdfs:label "Establishment details"@en ;
    rdfs:comment "The set of publicly viewable detail fields for an establishment record."@en .


#################################################################
# Classes - identity and identifiers
#################################################################

epr:EstablishmentIdentity
    a owl:Class ;
    rdfs:label "Establishment identity"@en ;
    rdfs:comment "The stable identity record of an establishment, grouping its persistent identifiers."@en .

epr:UniqueReferenceNumber
    a owl:Class ;
    rdfs:label "Unique Reference Number"@en ;
    rdfs:comment "The primary GIAS identifier for an establishment. Abbreviated URN."@en .

epr:UkProviderReferenceNumber
    a owl:Class ;
    rdfs:label "UK Provider Reference Number"@en ;
    rdfs:comment "An external cross-sector identifier assigned by the UKPRN register. Not the primary establishment key."@en .

epr:UniquePropertyReferenceNumber
    a owl:Class ;
    rdfs:label "Unique Property Reference Number"@en ;
    rdfs:comment "An Ordnance Survey identifier for the addressable property occupied by the establishment."@en .

epr:EstablishmentNumber
    a owl:Class ;
    rdfs:label "Establishment number"@en ;
    rdfs:comment "A locally assigned number used within a local authority area to identify an establishment."@en .

epr:DfeNumber
    a owl:Class ;
    rdfs:label "DfE number"@en ;
    rdfs:comment "A derived identifier combining local authority code and establishment number. Not independently stored."@en .

epr:FeHeIdentifier
    a owl:Class ;
    rdfs:label "FE/HE identifier"@en ;
    rdfs:comment "An optional identifier for further and higher education providers, recorded in GIAS for FE colleges, sixth form centres and HEIs. Separate from UKPRN."@en .

epr:LocalAuthorityScopedEstablishmentNumber
    a owl:Class ;
    rdfs:label "Local-authority-scoped establishment number"@en ;
    rdfs:comment "The establishment number together with the local authority context that makes it meaningful. Not globally unique without the LA code. Carries a role to distinguish current from previous identity."@en .

epr:IdentifierRole
    a owl:Class ;
    rdfs:label "Identifier role"@en ;
    rdfs:comment "The temporal role of a local-authority-scoped establishment number, distinguishing current from previous LAESTAB-style identity."@en .


#################################################################
# Classes - lifecycle
#################################################################

epr:EstablishmentLifecycle
    a owl:Class ;
    rdfs:label "Establishment lifecycle"@en ;
    rdfs:comment "The lifecycle record of an establishment, grouping its status and significant dates."@en .

epr:EstablishmentStatus
    a owl:Class ;
    rdfs:label "Establishment status"@en ;
    rdfs:comment "The current lifecycle or operating-state classification of an establishment. Values include open, closed, proposed to open and open proposed to close."@en .

epr:OpenDate
    a owl:Class ;
    rdfs:label "Open date"@en ;
    rdfs:comment "The date on which the establishment opened or was first registered."@en .

epr:ReasonEstablishmentOpened
    a owl:Class ;
    rdfs:label "Reason establishment opened"@en ;
    rdfs:comment "The classification describing why the establishment was opened."@en .

epr:ClosedDate
    a owl:Class ;
    rdfs:label "Closed date"@en ;
    rdfs:comment "The date on which the establishment closed."@en .

epr:ReasonEstablishmentClosed
    a owl:Class ;
    rdfs:label "Reason establishment closed"@en ;
    rdfs:comment "The classification describing why the establishment closed."@en .


#################################################################
# Classes - record currency
#################################################################

epr:RecordCurrencyAndStewardship
    a owl:Class ;
    rdfs:label "Record currency and stewardship"@en ;
    rdfs:comment "Metadata describing the currency and ownership of the GIAS establishment record itself, distinct from the lifecycle of the real-world establishment."@en .

epr:DateLastChangedOrConfirmed
    a owl:Class ;
    rdfs:label "Date last changed or confirmed"@en ;
    rdfs:comment "The date on which the establishment record was last updated or confirmed as current."@en .


#################################################################
# Classes - classification
#################################################################

epr:EstablishmentClassification
    a owl:Class ;
    rdfs:label "Establishment classification"@en ;
    rdfs:comment "The classification record grouping the establishment type, type group and education phase for an establishment."@en .

epr:EstablishmentType
    a owl:Class ;
    rdfs:label "Establishment type"@en ;
    rdfs:comment "The legal, operational or policy classification recorded as the establishment's type. An overloaded legacy classification."@en .

epr:EstablishmentTypeGroup
    a owl:Class ;
    rdfs:label "Establishment type group"@en ;
    rdfs:comment "A broad grouping of establishment types used for navigation and reporting."@en .

epr:EducationPhase
    a owl:Class ;
    rdfs:label "Education phase"@en ;
    rdfs:comment "The broad stage of education provided by the establishment."@en .


#################################################################
# Classes - accountability
#################################################################

epr:EstablishmentAccountability
    a owl:Class ;
    rdfs:label "Accountability relationship"@en ;
    rdfs:comment "A relationship between an establishment and the organisation accountable for it. An establishment may have zero or more accountability relationships of different kinds."@en .

epr:LocalAuthority
    a owl:Class ;
    rdfs:label "Local authority"@en ;
    rdfs:comment "A local government body maintaining or otherwise accountable for an establishment."@en .

epr:AcademyTrust
    a owl:Class ;
    rdfs:subClassOf epr:EstablishmentGroup ;
    rdfs:label "Academy trust"@en ;
    rdfs:comment "A charitable company limited by guarantee that enters into a funding agreement with the Secretary of State under the Academies Act 2010 to operate one or more academies or free schools. The trust is accountable for educational standards, financial management and employment of staff at its academies. An academy trust is simultaneously an accountability body (holding the funding agreement) and an establishment group (the organisational structure containing its academies)."@en .

epr:SingleAcademyTrust
    a owl:Class ;
    rdfs:label "Single academy trust"@en ;
    rdfs:comment "An academy trust constituted under the Academies Act 2010 that holds a funding agreement for exactly one academy. Distinguished from a multi-academy trust, which holds funding agreements for two or more academies. A SAT can expand into a MAT by taking on a second academy."@en ;
    rdfs:subClassOf epr:AcademyTrust .

epr:AcademySponsor
    a owl:Class ;
    rdfs:label "Academy sponsor"@en ;
    rdfs:comment "An approved body that sponsors one or more sponsor-led academies."@en .

epr:Proprietor
    a owl:Class ;
    rdfs:label "Proprietor"@en ;
    rdfs:comment "The person or body that owns or operates an independent school."@en .


#################################################################
# Classes - education, admissions and provision
#################################################################

epr:EducationAdmissionsAndProvision
    a owl:Class ;
    rdfs:label "Education, admissions and provision"@en ;
    rdfs:comment "The group of classification fields describing how an establishment admits pupils and what provision it offers."@en .

epr:StatutoryAgeRange
    a owl:Class ;
    rdfs:label "Statutory age range"@en ;
    rdfs:comment "The lower and upper statutory ages for which the establishment is registered."@en .

epr:GenderOfEntry
    a owl:Class ;
    rdfs:label "Gender of entry"@en ;
    rdfs:comment "The gender admission classification for the establishment."@en .

epr:AdmissionsPolicy
    a owl:Class ;
    rdfs:label "Admissions policy"@en ;
    rdfs:comment "The classification describing how places are allocated - selective or non-selective."@en .

epr:BoardingProvision
    a owl:Class ;
    rdfs:label "Boarding provision"@en ;
    rdfs:comment "The classification describing whether boarding places are offered."@en .

epr:NurseryProvision
    a owl:Class ;
    rdfs:label "Nursery provision"@en ;
    rdfs:comment "The classification describing whether the establishment offers nursery classes."@en .

epr:SixthFormProvision
    a owl:Class ;
    rdfs:label "Sixth-form provision"@en ;
    rdfs:comment "The classification describing whether the establishment has a sixth form."@en .

epr:SpecialClassProvision
    a owl:Class ;
    rdfs:label "Special-class provision"@en ;
    rdfs:comment "The classification describing whether the establishment has special classes."@en .


#################################################################
# Classes - capacity and pupil measures
#################################################################

epr:CapacityAndPupilMeasures
    a owl:Class ;
    rdfs:label "Capacity and pupil measures"@en ;
    rdfs:comment "The group of numeric measures describing an establishment's capacity and pupil population."@en .

epr:SchoolCapacity
    a owl:Class ;
    rdfs:label "School capacity"@en ;
    rdfs:comment "The total number of pupil places for which the establishment is registered. The name is a legacy field label - it applies to all establishment types."@en .

epr:PupilCount
    a owl:Class ;
    rdfs:label "Pupil count"@en ;
    rdfs:comment "The number of pupils on roll at the establishment at the census date."@en .

epr:PupilsEligibleForFreeSchoolMeals
    a owl:Class ;
    rdfs:label "Free school meal measure"@en ;
    rdfs:comment "The count and percentage of pupils eligible for free school meals. Includes both epr:PupilsEligibleForFreeSchoolMeals and epr:PercentagePupilsEligibleForFreeSchoolMeals."@en .


#################################################################
# Classes - faith context
#################################################################

epr:FaithContext
    a owl:Class ;
    rdfs:label "Faith context"@en ;
    rdfs:comment "The group of faith-related classification fields for an establishment."@en .

epr:ReligiousCharacter
    a owl:Class ;
    rdfs:label "Religious character"@en ;
    rdfs:comment "The formal religious-character classification designated for an establishment."@en .

epr:ReligiousEthos
    a owl:Class ;
    rdfs:label "Religious ethos"@en ;
    rdfs:comment "The recorded religious-ethos classification associated with an establishment."@en .

epr:Diocese
    a owl:Class ;
    rdfs:label "Diocese"@en ;
    rdfs:comment "The Church of England or Roman Catholic diocese associated with the establishment."@en .


#################################################################
# Classes - SEN and resourced provision
#################################################################

epr:SenAndResourcedProvision
    a owl:Class ;
    rdfs:label "SEN and resourced provision"@en ;
    rdfs:comment "The group of fields describing special educational needs provision and resourced-provision arrangements."@en .

epr:TypeOfSenProvision
    a owl:Class ;
    rdfs:label "Type of SEN provision"@en ;
    rdfs:comment "The classification describing the type of special educational needs provision offered."@en .

epr:TypeOfResourcedProvision
    a owl:Class ;
    rdfs:label "Type of resourced provision"@en ;
    rdfs:comment "The classification describing the type of resourced provision offered."@en .

epr:ResourcedProvisionMeasure
    a owl:Class ;
    rdfs:label "Resourced provision measure"@en ;
    rdfs:comment "Numeric measures for resourced provision. Corresponds to epr:ResourcedProvisionCapacity and epr:ResourcedProvisionPupilCount in the vocabulary."@en .

epr:SenUnitMeasure
    a owl:Class ;
    rdfs:label "SEN unit measure"@en ;
    rdfs:comment "Numeric measures for the SEN unit. Corresponds to epr:SenUnitCapacity and epr:SenUnitPupilCount in the vocabulary."@en .


#################################################################
# Classes - external references
#################################################################

epr:ExternalReference
    a owl:Class ;
    rdfs:label "External reference"@en ;
    rdfs:comment "A link from the establishment record to a resource held in an external system or publication."@en .

epr:InspectionReportReference
    a owl:Class ;
    rdfs:label "Inspection report reference"@en ;
    rdfs:comment "A link to an inspection report published by the relevant inspectorate."@en .

epr:ExternalServiceReference
    a owl:Class ;
    rdfs:label "External service reference"@en ;
    rdfs:comment "A link to a record in an external service such as a companies register or accreditation body."@en .


#################################################################
# Object properties - core structure
#################################################################

epro:hasEstablishmentDetails
    a owl:ObjectProperty ;
    rdfs:label "has establishment details"@en ;
    rdfs:domain epr:Establishment ;
    rdfs:range epr:EstablishmentDetails ;
    rdfs:comment "Cardinality: exactly 1. Every establishment has exactly one set of details in this slice."@en .


#################################################################
# Object properties - identity and lifecycle
#################################################################

epro:hasEstablishmentIdentity
    a owl:ObjectProperty ;
    rdfs:label "has establishment identity"@en ;
    rdfs:domain epr:Establishment ;
    rdfs:range epr:EstablishmentIdentity ;
    rdfs:comment "Cardinality: exactly 1. Every establishment has exactly one identity record."@en .

epro:hasEstablishmentLifecycle
    a owl:ObjectProperty ;
    rdfs:label "has establishment lifecycle"@en ;
    rdfs:domain epr:Establishment ;
    rdfs:range epr:EstablishmentLifecycle ;
    rdfs:comment "Cardinality: exactly 1. Every establishment has exactly one lifecycle record."@en .

epro:hasRecordCurrency
    a owl:ObjectProperty ;
    rdfs:label "has record currency"@en ;
    rdfs:domain epr:Establishment ;
    rdfs:range epr:RecordCurrencyAndStewardship ;
    rdfs:comment "Cardinality: 0..1. An establishment record may have a record-currency block."@en .

epro:identifiedByUrn
    a owl:ObjectProperty ;
    rdfs:label "identified by URN"@en ;
    rdfs:domain epr:EstablishmentIdentity ;
    rdfs:range epr:UniqueReferenceNumber ;
    rdfs:comment "Cardinality: exactly 1. Every establishment identity is identified by exactly one URN."@en .

epro:hasUkprn
    a owl:ObjectProperty ;
    rdfs:label "has UKPRN"@en ;
    rdfs:domain epr:EstablishmentIdentity ;
    rdfs:range epr:UkProviderReferenceNumber ;
    rdfs:comment "Cardinality: 0..1. An establishment identity may have a UK provider reference number."@en .

epro:hasUprn
    a owl:ObjectProperty ;
    rdfs:label "has UPRN"@en ;
    rdfs:domain epr:MainAddress ;
    rdfs:range epr:UniquePropertyReferenceNumber ;
    rdfs:comment "Cardinality: 0..1. An address may carry a unique property reference number. UPRN identifies a property, not an establishment - domain moved from EstablishmentIdentity to MainAddress (v1.0)."@en .

epro:hasLocalAuthorityScopedEstablishmentNumber
    a owl:ObjectProperty ;
    rdfs:label "has local-authority-scoped establishment number"@en ;
    rdfs:domain epr:EstablishmentIdentity ;
    rdfs:range epr:LocalAuthorityScopedEstablishmentNumber ;
    rdfs:comment "Cardinality: 0..2. An identity may have a current and/or previous scoped establishment number. Replaces bare epro:hasEstablishmentNumber (v1.0) - establishment number is not globally unique without its LA context."@en .

epro:hasLocalAuthorityContext
    a owl:ObjectProperty ;
    rdfs:label "has local authority context"@en ;
    rdfs:domain epr:LocalAuthorityScopedEstablishmentNumber ;
    rdfs:range epr:LocalAuthority ;
    rdfs:comment "Cardinality: exactly 1. Every scoped establishment number must carry exactly one local authority context."@en .

epro:hasEstablishmentNumberValue
    a owl:ObjectProperty ;
    rdfs:label "has establishment number value"@en ;
    rdfs:domain epr:LocalAuthorityScopedEstablishmentNumber ;
    rdfs:range epr:EstablishmentNumber ;
    rdfs:comment "Cardinality: exactly 1. Every scoped establishment number carries the one-to-four digit establishment number value."@en .

epro:hasIdentifierRole
    a owl:ObjectProperty ;
    rdfs:label "has identifier role"@en ;
    rdfs:domain epr:LocalAuthorityScopedEstablishmentNumber ;
    rdfs:range epr:IdentifierRole ;
    rdfs:comment "Cardinality: exactly 1. Distinguishes current from previous LAESTAB-style identity."@en .

epro:hasFeHeIdentifier
    a owl:ObjectProperty ;
    rdfs:label "has FE/HE identifier"@en ;
    rdfs:domain epr:EstablishmentIdentity ;
    rdfs:range epr:FeHeIdentifier ;
    rdfs:comment "Cardinality: 0..1. Present only for further education colleges, sixth form centres and higher education institutions."@en .

epro:derivesDfeNumber
    a owl:ObjectProperty ;
    rdfs:label "derives DfE number"@en ;
    rdfs:domain epr:EstablishmentIdentity ;
    rdfs:range epr:DfeNumber ;
    rdfs:comment "Cardinality: 0..1. A DfE number is derived from local-authority code and establishment number, not independently stored."@en .

epro:classifiedByEstablishmentStatus
    a owl:ObjectProperty ;
    rdfs:label "classified by establishment status"@en ;
    rdfs:domain epr:EstablishmentLifecycle ;
    rdfs:range epr:EstablishmentStatus ;
    rdfs:comment "Cardinality: exactly 1. Every establishment lifecycle must have an establishment status."@en .

epro:hasOpenDate
    a owl:ObjectProperty ;
    rdfs:label "has open date"@en ;
    rdfs:domain epr:EstablishmentLifecycle ;
    rdfs:range epr:OpenDate ;
    rdfs:comment "Cardinality: 0..1."@en .

epro:hasReasonEstablishmentOpened
    a owl:ObjectProperty ;
    rdfs:label "has reason establishment opened"@en ;
    rdfs:domain epr:EstablishmentLifecycle ;
    rdfs:range epr:ReasonEstablishmentOpened ;
    rdfs:comment "Cardinality: 0..1."@en .

epro:hasClosedDate
    a owl:ObjectProperty ;
    rdfs:label "has closed date"@en ;
    rdfs:domain epr:EstablishmentLifecycle ;
    rdfs:range epr:ClosedDate ;
    rdfs:comment "Cardinality: 0..1. Only present if establishment status is closed."@en .

epro:hasReasonEstablishmentClosed
    a owl:ObjectProperty ;
    rdfs:label "has reason establishment closed"@en ;
    rdfs:domain epr:EstablishmentLifecycle ;
    rdfs:range epr:ReasonEstablishmentClosed ;
    rdfs:comment "Cardinality: 0..1. Only present if establishment status is closed."@en .

epro:recordsDateLastChanged
    a owl:ObjectProperty ;
    rdfs:label "records date last changed or confirmed"@en ;
    rdfs:domain epr:RecordCurrencyAndStewardship ;
    rdfs:range epr:DateLastChangedOrConfirmed ;
    rdfs:comment "Cardinality: 0..1."@en .


#################################################################
# Object properties - classification and accountability
#################################################################

epro:hasEstablishmentClassification
    a owl:ObjectProperty ;
    rdfs:label "has establishment classification"@en ;
    rdfs:domain epr:Establishment ;
    rdfs:range epr:EstablishmentClassification ;
    rdfs:comment "Cardinality: exactly 1. Every establishment has exactly one classification record."@en .

epro:hasEstablishmentType
    a owl:ObjectProperty ;
    rdfs:label "has establishment type"@en ;
    rdfs:domain epr:EstablishmentClassification ;
    rdfs:range epr:EstablishmentType ;
    rdfs:comment "Cardinality: exactly 1. Every classification record must have an establishment type."@en .

epro:hasEstablishmentTypeGroup
    a owl:ObjectProperty ;
    rdfs:label "has establishment type group"@en ;
    rdfs:domain epr:EstablishmentClassification ;
    rdfs:range epr:EstablishmentTypeGroup ;
    rdfs:comment "Cardinality: 0..1. An establishment type may belong to a type group."@en .

epro:hasEducationPhase
    a owl:ObjectProperty ;
    rdfs:label "has education phase"@en ;
    rdfs:domain epr:EstablishmentClassification ;
    rdfs:range epr:EducationPhase ;
    rdfs:comment "Cardinality: 0..1. Not all establishment types have an education phase."@en .

epro:hasAccountabilityRelationship
    a owl:ObjectProperty ;
    rdfs:label "has accountability relationship"@en ;
    rdfs:domain epr:Establishment ;
    rdfs:range epr:EstablishmentAccountability ;
    rdfs:comment "Cardinality: 0..*. An establishment may have zero or more accountability relationships depending on its type."@en .

epro:accountableToLocalAuthority
    a owl:ObjectProperty ;
    rdfs:label "accountable to local authority"@en ;
