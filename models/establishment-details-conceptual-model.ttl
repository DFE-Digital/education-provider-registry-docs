#################################################################
# Classes - contact and location
#################################################################

epr:EstablishmentLocationAndContact
    a owl:Class ;
    rdfs:label "Contact and location"@en ;
    rdfs:comment "The group of fields describing how to contact and locate the establishment physically."@en .

epr:MainAddress
    a owl:Class ;
    rdfs:label "Postal address"@en ;
    rdfs:comment "The physical or postal address at which the establishment is located."@en .

epr:Website
    a owl:Class ;
    rdfs:label "Website"@en ;
    rdfs:comment "The establishment's public website URL."@en .

epr:TelephoneNumber
    a owl:Class ;
    rdfs:label "Telephone number"@en ;
    rdfs:comment "The establishment's main contact telephone number."@en .

epr:HeadteacherOrPrincipal
    a owl:Class ;
    rdfs:label "Headteacher or principal"@en ;
    rdfs:comment "The named person leading the establishment. The GIAS UI label varies by type: Headteacher / Principal for most schools; Manager for children's centres; Headteacher/Manager for online providers. Treated as a single concept in the EPR model."@en .


#################################################################
# Classes - further education sub-classification and Section 41
#################################################################

epr:FurtherEducationType
    a owl:Class ;
    rdfs:label "Further education type"@en ;
    rdfs:comment "A sub-classification of further education and pupil referral unit establishments. Observed for FE colleges (type 18), higher education institutions (type 29) and pupil referral units (type 14)."@en .

epr:Section41Approval
    a owl:Class ;
    rdfs:label "Section 41 approval status"@en ;
    rdfs:comment "Whether the establishment is approved under Section 41 of the Children and Families Act 2014 to accept placements of pupils with education, health and care plans."@en .


#################################################################
# Classes - inspection detail (non-Ofsted inspectorates and BSO)
#################################################################

epr:InspectorateName
    a owl:Class ;
    rdfs:label "Inspectorate name"@en ;
    rdfs:comment "The name of the inspectorate body responsible for inspecting the establishment. Used for independent schools and British schools overseas where the inspectorate is not Ofsted."@en .

epr:DateOfLastInspectionVisit
    a owl:Class ;
    rdfs:label "Date of last inspection visit"@en ;
    rdfs:comment "The date of the most recent inspection visit by the named inspectorate. Observed for British schools overseas (type 37) and independent schools."@en .

epr:DateOfNextInspectionVisit
    a owl:Class ;
    rdfs:label "Date of next inspection visit"@en ;
    rdfs:comment "The scheduled date of the next inspection visit. Observed for British schools overseas (type 37)."@en .


#################################################################
# Classes - special pupils SEN measures
#################################################################

epr:SpecialPupilMeasure
    a owl:Class ;
    rdfs:label "Special pupil measure"@en ;
    rdfs:comment "Numeric measures for pupils with special educational needs. Covers the count of pupils with a SEN statement or education, health and care plan and the count of pupils with SEN needs but without such a plan."@en .


