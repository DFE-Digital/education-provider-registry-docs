# ─── 1.5  Education phase group  (INCLUDE — all new) ────────────────────────

epr:educationPhaseGroupScheme
    a skos:ConceptScheme ;
    dcterms:title "Education phase group"@en ;
    dcterms:source "EducationPhaseGroup"@en ;
    epr:status "Draft"@en .

epr:EducationPhaseGroup
    a skos:Concept, owl:NamedIndividual ;
    skos:inScheme epr:educationPhaseGroupScheme ;
    skos:topConceptOf epr:educationPhaseGroupScheme ;
    skos:prefLabel "Education phase group"@en ;
    skos:definition "Broad phase grouping for education phases. Groups the EducationPhase code list into a smaller set of phase bands."@en ;
    skos:narrower
        epr:NotApplicablePhaseGroup,
        epr:NurseryPhaseGroup,
        epr:PrimaryPhaseGroup,
        epr:SecondaryPhaseGroup,
        epr:SixteenPlusPhaseGroup,
        epr:AllThroughPhaseGroup,
        epr:NotRecordedPhaseGroup ;
    epr:status "active"@en .

epr:NotApplicablePhaseGroup
    a skos:Concept, owl:NamedIndividual ;
    skos:inScheme epr:educationPhaseGroupScheme ;
