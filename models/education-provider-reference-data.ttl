epr:NotApplicableEducationPhase  skos:inScheme epr:educationPhaseScheme ; skos:notation "0" ; epr:status "active"@en .
epr:NurseryPhase                 skos:inScheme epr:educationPhaseScheme ; skos:notation "1" ; epr:status "active"@en .
