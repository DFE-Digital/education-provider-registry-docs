# ─── 2.1  Reason establishment opened  (INCLUDE) ────────────────────────────

epr:reasonEstablishmentOpenedScheme
    a skos:ConceptScheme ;
    dcterms:title "Reason establishment opened"@en ;
    dcterms:source "ReasonEstablishmentOpened"@en ;
    epr:status "Draft"@en .

epr:ReasonEstablishmentOpened
    a skos:Concept, owl:NamedIndividual ;
    skos:inScheme epr:reasonEstablishmentOpenedScheme ;
    skos:topConceptOf epr:reasonEstablishmentOpenedScheme ;
    skos:prefLabel "Reason establishment opened"@en ;
    skos:definition "The classification of why an establishment was opened or created."@en ;
    skos:narrower
        epr:OpenedNotApplicable, epr:OpenedResultOfAmalgamation, epr:OpenedResultOfClosure,
        epr:OpenedChangeReligiousCharacter, epr:OpenedFreshStart, epr:OpenedNewNurserySchool,
        epr:OpenedNewProvision, epr:OpenedFormerIndependent, epr:OpenedSplitSchool,
        epr:OpenedChangeInStatus, epr:OpenedAcademyConverter, epr:OpenedAcademyFreeSchool,
        epr:OpenedFreeSpecialSchool, epr:OpenedNotRecorded13, epr:OpenedMeetsAccreditationStandards,
        epr:OpenedNotRecorded99 ;
    epr:status "active"@en .

