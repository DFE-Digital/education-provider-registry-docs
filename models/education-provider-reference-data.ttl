@prefix epr: <https://dfe-digital.github.io/education-provider-registry-docs/vocabulary/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# Education Provider Reference Data
#
# SSOT for GIAS code-list reference data. Each code list is a separate
# skos:ConceptScheme. "Extend" schemes add source codes and missing values
# to concepts already declared in education-provider-taxonomy.ttl. "Include"
# schemes fully declare new concept sets not previously in the taxonomy.
#
# Source: GIAS database reference tables as documented in docs/data/erd/.
# Sourced: 2026-06-26

epr:educationProviderReferenceData
    a owl:Ontology ;
    dcterms:title "Education Provider Reference Data"@en ;
    dcterms:description "SKOS concept schemes for all GIAS reference data code lists. Single source of truth for provider-facing controlled vocabularies."@en ;
    dcterms:created "2026-06-26"^^xsd:date ;
    dcterms:modified "2026-06-26"^^xsd:date ;
    epr:status "Draft"@en .

