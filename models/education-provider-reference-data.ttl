    skos:inScheme epr:reasonEstablishmentClosedScheme ;
    skos:topConceptOf epr:reasonEstablishmentClosedScheme ;
    skos:prefLabel "Reason establishment closed"@en ;
    skos:definition "The classification of why an establishment was closed or de-registered."@en ;
    skos:narrower
        epr:ClosedNotApplicable, epr:ClosedAmalgamation, epr:ClosedClosure,
        epr:ClosedChangeReligiousCharacter, epr:ClosedFreshStart, epr:ClosedNurserySchool,
        epr:ClosedForAcademy, epr:ClosedDeRegistered, epr:ClosedNotMeetCriteria,
        epr:ClosedChangeInStatus, epr:ClosedAcademyConverter, epr:ClosedAcademyFreeSchool,
        epr:ClosedTransferredNewSponsor, epr:ClosedCreatedInErrorConversion,
        epr:ClosedCreatedInErrorApplicationRejected, epr:ClosedNoLongerMeetsAccreditation,
        epr:ClosedNotRecorded ;
    epr:status "active"@en .

