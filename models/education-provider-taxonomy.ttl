    epr:status "Provisional"@en .

epr:MaintainedNurserySchool
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Maintained nursery school"@en ;
    skos:broader epr:EstablishmentTypeGroupLaMaintainedSchools ;
    epr:legislation <https://www.legislation.gov.uk/ukpga/1998/31/section/22> ;
    dcterms:source "Type code 15"@en ;
    epr:status "Provisional"@en .

#################################################################
# Establishment-type taxons - group 5: non-maintained special schools
#################################################################

epr:NonMaintainedSpecialSchool
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Non-maintained special school"@en ;
    skos:broader epr:EstablishmentTypeGroupNonMaintainedSpecialSchools ;
    rdfs:isDefinedBy <https://www.gov.uk/government/publications/non-maintained-special-schools-intervention-and-accountability> ;
    epr:legislation <https://www.legislation.gov.uk/ukpga/1996/56/section/342> ;
    dcterms:source "Type code 08"@en ;
    epr:status "Provisional"@en .

epr:OtherIndependentSpecialSchool
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Other independent special school"@en ;
    skos:scopeNote "GIAS construct. Residual category for independent schools providing special education that are not non-maintained special schools. The 'other' qualifier has no equivalent in legislation or GOV.UK guidance."@en ;
    skos:broader epr:EstablishmentTypeGroupNonMaintainedSpecialSchools ;
    dcterms:source "Type code 10"@en ;
    epr:status "Provisional"@en .

