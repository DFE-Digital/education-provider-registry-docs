#################################################################
# Establishment-group-type facet (v1.1)
#################################################################

epr:EstablishmentGroupType
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:topConceptOf epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Establishment group type"@en ;
    skos:definition "The classification of an establishment group by its type, corresponding to EstablishmentGroupType codes in GIAS."@en ;
    skos:scopeNote "Active group types only (codes 01, 02, 05, 06, 08, 09, 10, 11). Three archived group types are intentionally excluded. Code 03 (Collegiate) and code 04 (Partnership) have no rows in current GIAS data and no public service representation. Code 07 (Umbrella trust) has approximately 20 legacy rows in current data but does not render a public group details page on the GIAS service; it is retained in the data for historical continuity only."@en ;
    skos:narrower
        epr:Federation,
        epr:GenericTrust,
        epr:SchoolSponsor,
        epr:MultiAcademyTrust,
        epr:ChildrensCentreGroup,
        epr:ChildrensCentreCollaboration,
        epr:SingleAcademyTrust,
        epr:SecureSingleAcademyTrust ;
    epr:status "Provisional"@en .

epr:Federation
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Federation"@en ;
    skos:broader epr:EstablishmentGroupType ;
    rdfs:isDefinedBy <https://www.gov.uk/government/publications/maintained-schools-governance-guide/maintained-schools-governance-guide> ;
    epr:legislation <https://www.legislation.gov.uk/uksi/2012/1035/contents> ;
    dcterms:source "Group type code 01"@en ;
    epr:status "Provisional"@en .

epr:GenericTrust
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
