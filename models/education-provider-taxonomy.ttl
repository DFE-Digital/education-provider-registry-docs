@prefix epr: <https://dfe-digital.github.io/education-provider-registry-docs/vocabulary/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Education Provider Registry Taxonomy
#
# Scope: this version covers classifications used by the fields shown in the
# establishment record Details tab in the public view.
#
# Facets are represented as top concepts. Taxons are narrower concepts beneath
# their facet. Establishment types are represented as taxons under
# EstablishmentType, with an intermediate type-group level. Dates, identifiers,
# measures and organisation relationships are excluded because they are not
# taxonomy classifications.
#
# It is not a complete provider-domain taxonomy and does not attempt to classify
# fields outside the establishment record Details tab.


epr:establishmentDetailsTaxonomy
    a skos:ConceptScheme ;
    dcterms:title "Education Provider Registry Taxonomy"@en ;
    dcterms:description "Faceted taxonomy containing classifications used by the fields shown in the establishment record Details tab in the public view."@en ;
    dcterms:created "2026-06-16"^^xsd:date ;
    dcterms:modified "2026-06-24"^^xsd:date ;
    epr:status "Provisional"@en ;
    skos:hasTopConcept
        epr:EstablishmentType,
        epr:EducationPhase,
        epr:EstablishmentStatus,
        epr:AdmissionsPolicy,
        epr:GenderOfEntry,
        epr:BoardingProvision,
        epr:NurseryProvision,
        epr:SixthFormProvision,
        epr:SpecialClassProvision,
        epr:ReligiousCharacter,
        epr:ReligiousEthos,
        epr:EstablishmentGroupType,
        epr:GroupRelationshipType,
        epr:GovernanceRoleType,
        epr:GovernanceAppointingBody .

#################################################################
# Facet collection
#################################################################

epr:establishmentDetailsTaxonomyFacets
    a skos:Collection ;
    skos:prefLabel "Education provider taxonomy facets"@en ;
    skos:member
        epr:EstablishmentType,
        epr:EducationPhase,
        epr:EstablishmentStatus,
        epr:AdmissionsPolicy,
        epr:GenderOfEntry,
        epr:BoardingProvision,
        epr:NurseryProvision,
        epr:SixthFormProvision,
        epr:SpecialClassProvision,
        epr:ReligiousCharacter,
        epr:ReligiousEthos,
        epr:EstablishmentGroupType,
        epr:GroupRelationshipType,
        epr:GovernanceRoleType,
        epr:GovernanceAppointingBody .

#################################################################
# Type-group collection
#################################################################

epr:establishmentTypeGroups
    a skos:Collection ;
    skos:prefLabel "Establishment type groups"@en ;
    skos:member
        epr:EstablishmentTypeGroupColleges,
        epr:EstablishmentTypeGroupUniversities,
        epr:EstablishmentTypeGroupIndependentSchools,
        epr:EstablishmentTypeGroupLaMaintainedSchools,
        epr:EstablishmentTypeGroupNonMaintainedSpecialSchools,
        epr:EstablishmentTypeGroupWelshEstablishments,
        epr:EstablishmentTypeGroupOtherTypes,
        epr:EstablishmentTypeGroupAcademies,
        epr:EstablishmentTypeGroupFreeSchools,
        epr:EstablishmentTypeGroupChildrensCentres,
        epr:EstablishmentTypeGroupOnlineProviders .

#################################################################
# Facets
#################################################################

epr:EstablishmentType
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:topConceptOf epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Establishment type"@en ;
    skos:definition "The legal, operational or policy classification recorded as the establishment's type."@en ;
    skos:scopeNote "This remains an overloaded legacy classification mixing legal form, sector and operational model. The intermediate type-group level is retained for traceability."@en ;
    skos:narrower
        epr:EstablishmentTypeGroupAcademies,
        epr:EstablishmentTypeGroupChildrensCentres,
        epr:EstablishmentTypeGroupColleges,
        epr:EstablishmentTypeGroupFreeSchools,
        epr:EstablishmentTypeGroupIndependentSchools,
        epr:EstablishmentTypeGroupLaMaintainedSchools,
        epr:EstablishmentTypeGroupNonMaintainedSpecialSchools,
        epr:EstablishmentTypeGroupOnlineProviders,
        epr:EstablishmentTypeGroupOtherTypes,
        epr:EstablishmentTypeGroupUniversities,
        epr:EstablishmentTypeGroupWelshEstablishments ;
    epr:status "Provisional"@en .

epr:EducationPhase
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:topConceptOf epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Education phase"@en ;
    skos:definition "The broad stage of education provided by an establishment."@en ;
    skos:narrower
        epr:NurseryPhase,
        epr:PrimaryPhase,
        epr:MiddlePhase,
        epr:MiddleDeemedSecondaryPhase,
        epr:SecondaryPhase,
        epr:AllThroughPhase,
        epr:SixteenToNineteenPhase,
        epr:NotApplicableEducationPhase ;
    epr:status "Provisional"@en .

epr:EstablishmentStatus
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:topConceptOf epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Establishment status"@en ;
    skos:definition "The current lifecycle or operating-state classification of an establishment."@en ;
    skos:narrower
        epr:OpenStatus,
        epr:ClosedStatus,
        epr:OpenProposedToCloseStatus,
        epr:ProposedToOpenStatus ;
    epr:status "Provisional"@en .

epr:AdmissionsPolicy
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:topConceptOf epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Admissions policy"@en ;
    skos:definition "The classification describing how places are allocated."@en ;
    skos:narrower
        epr:SelectiveAdmissions,
        epr:NonSelectiveAdmissions,
        epr:NotApplicableAdmissionsPolicy ;
    epr:status "Provisional"@en .

epr:GenderOfEntry
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:topConceptOf epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Gender of entry"@en ;
    skos:definition "The classification describing the establishment's gender admission arrangement."@en ;
    skos:narrower
        epr:BoysOnlyGenderEntry,
        epr:GirlsOnlyGenderEntry,
        epr:MixedGenderEntry,
        epr:NotApplicableGenderOfEntry ;
    epr:status "Provisional"@en .

epr:BoardingProvision
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:topConceptOf epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Boarding provision"@en ;
    skos:definition "The classification describing whether boarding places are offered."@en ;
    skos:narrower
        epr:BoardingSchool,
        epr:HasBoarders,
        epr:NoBoarders ;
    epr:status "Provisional"@en .

epr:NurseryProvision
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:topConceptOf epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Nursery provision"@en ;
    skos:definition "The classification describing whether the establishment offers nursery classes."@en ;
    skos:narrower
        epr:HasNurseryClasses,
        epr:NoNurseryClasses,
        epr:NotApplicableNurseryProvision ;
    epr:status "Provisional"@en .

epr:SixthFormProvision
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:topConceptOf epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Sixth-form provision"@en ;
    skos:definition "The classification describing whether the establishment has a sixth form."@en ;
    skos:narrower
        epr:HasSixthForm,
        epr:NoSixthForm,
        epr:NotApplicableSixthFormProvision ;
    epr:status "Provisional"@en .

epr:SpecialClassProvision
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:topConceptOf epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Special-class provision"@en ;
    skos:definition "The classification describing whether the establishment has special classes."@en ;
    skos:narrower
        epr:HasSpecialClasses,
        epr:NoSpecialClasses,
        epr:NotApplicableSpecialClassProvision ;
    epr:status "Provisional"@en .

epr:ReligiousCharacter
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:topConceptOf epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Religious character"@en ;
    skos:definition "The formal religious-character classification designated for an establishment."@en ;
    skos:narrower
        epr:ChurchOfEnglandCharacter,
        epr:JewishCharacter,
        epr:MuslimCharacter,
        epr:NoReligiousCharacter,
        epr:NotApplicableReligiousCharacter,
        epr:OtherReligiousCharacter,
        epr:RomanCatholicCharacter ;
    epr:status "Provisional"@en .

epr:ReligiousEthos
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:topConceptOf epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Religious ethos"@en ;
    skos:definition "The recorded religious-ethos classification associated with an establishment."@en ;
    skos:scopeNote "Its distinction from religious character requires business validation."@en ;
    skos:narrower
        epr:ChristianEthos,
        epr:NoReligiousEthos,
        epr:NotApplicableReligiousEthos,
        epr:OtherReligiousEthos ;
    epr:status "Provisional"@en .

