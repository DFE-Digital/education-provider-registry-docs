    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Higher education institution"@en ;
    skos:altLabel "HEI"@en ;
    skos:broader epr:EstablishmentTypeGroupUniversities ;
    epr:legislation <https://www.legislation.gov.uk/ukpga/2017/29/section/83> ;
    dcterms:source "Type code 29"@en ;
    epr:status "Provisional"@en .

#################################################################
# Establishment-type taxons - group 6: Welsh establishments
#################################################################

epr:WelshEstablishment
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Welsh establishment"@en ;
    skos:scopeNote "GIAS construct. Administrative category for schools in Wales appearing in DfE data for cross-border purposes. Welsh school types are governed by Senedd Cymru and are not defined on GOV.UK."@en ;
    skos:broader epr:EstablishmentTypeGroupWelshEstablishments ;
    dcterms:source "Type code 30"@en ;
    epr:status "Provisional"@en .

#################################################################
# Establishment-type taxons - other types
#################################################################

epr:SecureUnits
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Secure units"@en ;
    skos:scopeNote "Real-world (limited). Secure residential facilities with education provision are real and referenced on GOV.UK, but 'Secure units' as an establishment type label is a GIAS administrative grouping, not a GOV.UK-defined term."@en ;
    skos:broader epr:EstablishmentTypeGroupOtherTypes ;
    dcterms:references <https://www.gov.uk/government/collections/youth-justice-statistics> ;
    dcterms:source "Type code 24"@en ;
    epr:status "Provisional"@en .

epr:OffshoreSchools
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
