#################################################################
# Establishment-type taxons - group 1: colleges
#################################################################

epr:FurtherEducation
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Further education"@en ;
    skos:altLabel "Further education college"@en ;
    skos:broader epr:EstablishmentTypeGroupColleges ;
    rdfs:isDefinedBy <https://www.gov.uk/further-education-courses/types-of-further-education> ;
    dcterms:source "Type code 18"@en ;
    epr:status "Provisional"@en .

epr:SixthFormCentre
    a skos:Concept ;
    skos:inScheme epr:establishmentDetailsTaxonomy ;
    skos:prefLabel "Sixth form centre"@en ;
    skos:scopeNote "Real-world (limited). LA sixth form arrangements pre-2010; most are closed. No current GOV.UK policy page defines this as an active establishment type."@en ;
    skos:broader epr:EstablishmentTypeGroupColleges ;
    dcterms:references <https://www.gov.uk/further-education-courses/types-of-further-education> ;
    dcterms:source "Type code 31"@en ;
    epr:status "Provisional"@en .

