@prefix epr:     <https://dfe-digital.github.io/education-provider-registry-docs/vocabulary/> .
@prefix rdf:     <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:    <http://www.w3.org/2000/01/rdf-schema#> .
@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# Provider Field Coverage
#
# This file is the single source of truth for which GIAS UI fields are visible
# for each establishment type on each of the four public tabs:
#   Details, Location, Governance, Links (groups)
#
# Source evidence: docs/data/extract-data — observed GIAS public page rendering,
# June 2026. One representative establishment per type.
#
# Each block annotates an existing epr: vocabulary concept with:
#   epr:shownOnTab             — which tab (epr:detailsTab etc.)
#   epr:uiLabel                — the field label as rendered in the GIAS UI
#   epr:applicableToEstablishmentType — two-digit string type codes where the
#                                field is shown. Blank = not shown for that type.
#
# Type codes in scope (41 observed types):
#   01 Community school                        15 LA nursery school
#   02 Voluntary aided school                  18 Further education
#   03 Voluntary controlled school             24 Secure units
#   05 Foundation school                       25 Offshore schools
#   06 City technology college                 26 Service children's education
#   07 Community special school                27 Miscellaneous
#   08 Non-maintained special school           28 Academy sponsor led
#   10 Other independent special school        29 Higher education institutions
#   11 Other independent school                30 Welsh establishment
#   12 Foundation special school               31 Sixth form centres
#   14 Pupil referral unit                     32 Special post 16 institution
#                                              33 Academy special sponsor led
#   34 Academy converter                       47 Children's centre
#   35 Free schools                            48 Children's centre linked site
#   36 Free schools special                    49 Online provider
#   37 British schools overseas                56 Institution funded by OGD
#   38 Free schools alternative provision      57 Academy secure 16 to 19
#   39 Free schools 16 to 19
#   40 University technical college
#   41 Studio schools
#   42 Academy AP converter
#   43 Academy AP sponsor led
#   44 Academy special converter
#   45 Academy 16-19 converter
#   46 Academy 16 to 19 sponsor led
#
# Types not observed (no sample in extracts): 09, 17, 22, 23, 98
#
# Version: 1.0 — 2026-06-26

#################################################################
# Annotation property declarations
#################################################################

epr:shownOnTab
    a rdf:Property ;
    rdfs:label "shown on tab"@en ;
    rdfs:comment "The GIAS UI tab on which this vocabulary concept is rendered as a visible field."@en .

epr:uiLabel
    a rdf:Property ;
    rdfs:label "UI label"@en ;
    rdfs:comment "The field label as displayed in the GIAS public UI. May differ from the vocabulary prefLabel."@en .

epr:applicableToEstablishmentType
    a rdf:Property ;
    rdfs:label "applicable to establishment type"@en ;
    rdfs:comment "Two-digit establishment type codes for which this field is displayed on the relevant tab. Source: observed GIAS page rendering, June 2026."@en .

#################################################################
# Tab resources
#################################################################

epr:detailsTab
    a epr:UITab ;
    rdfs:label "Details"@en ;
    rdfs:comment "The main Details tab on a GIAS establishment page."@en .

epr:locationTab
    a epr:UITab ;
    rdfs:label "Location"@en ;
    rdfs:comment "The Location tab on a GIAS establishment page."@en .

epr:governanceTab
    a epr:UITab ;
    rdfs:label "Governance"@en ;
    rdfs:comment "The Governance tab on a GIAS establishment page."@en .

epr:linksTab
    a epr:UITab ;
    rdfs:label "Links"@en ;
    rdfs:comment "The Links tab on a GIAS establishment page, showing group membership information."@en .

epr:UITab
    a rdfs:Class ;
    rdfs:label "UI tab"@en ;
    rdfs:comment "A named tab on the GIAS establishment details page."@en .


